														onmouseover="this.style.backgroundColor='var(--fondoBotonPequeñoHover)'"
														onmouseout="this.style.backgroundColor='var(--fondoBotonPequeño)'">
														<div style="display: flex; align-items: center; gap: 10px;">
															<div style="width: 20px; height: 20px; display: flex; fill: var(--colorTexto);">
																@if (destacadoActual.Color == "var(--fondoAlerta)")

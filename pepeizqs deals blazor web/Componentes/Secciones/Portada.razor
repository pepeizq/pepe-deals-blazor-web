											<source srcset="@iconoDRM1 1x, @iconoDRM2 2x" type="image/webp">
											<img class="destacado-icono" src="@iconoDRM" alt="@JuegoDRM2.DevolverDRM(drmDestacado)" />
										</picture>
									</div>

									string iconoTienda1 = iconoTienda.Replace(".webp", "-sm.webp");
									string iconoTienda2 = iconoTienda.Replace(".webp", "-md.webp");

									<div style="display: flex; margin-right: 40px;">
										<picture>
											<source srcset="@iconoTienda1 1x, @iconoTienda2 2x" type="image/webp">
											<img class="destacado-icono" src="@iconoTienda" alt="@nombreTienda" />
										</picture>
									</div>

									<div class="destacado-sombra" style="display: flex; align-items: center;">
										<div class="destacado-precio-descuento" style="background-color: darkgreen;">
											@descuento%
										</div>
										<div class="destacado-precio-descuento" style="background-color: var(--fondoOscuro);">
											@precioMostrar
										</div>
									</div>

									@if (string.IsNullOrEmpty(usuarioId) == false && destacadoActual?.Color != "var(--fondoBien)" && destacadoActual?.DesplegableMostrar == true)
									{
										JuegoDRM drmDeseado = JuegoDRM.NoEspecificado;

										if (usuarioRegion == TiendaRegion.Europa)
										{
											drmDeseado = destacadoActual?.Juego?.PrecioMinimosHistoricos?[0].DRM ?? JuegoDRM.NoEspecificado;
										}
										else if (usuarioRegion == TiendaRegion.EstadosUnidos)
										{
											drmDeseado = destacadoActual?.Juego?.PrecioMinimosHistoricosUS?[0].DRM ?? JuegoDRM.NoEspecificado;
										}


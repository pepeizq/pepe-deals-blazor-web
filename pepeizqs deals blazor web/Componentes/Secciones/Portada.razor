					</div>
				}
			}
		</div>
	</div>
}

@if (noticias?.Count > 0)
{
	<div class="caja-portada-noticias" style="padding: 30px; background-color: var(--fondoPortadaNoticias2); border-top: 1px solid var(--bordePortadaNoticias); border-bottom: 1px solid var(--bordePortadaNoticias);">

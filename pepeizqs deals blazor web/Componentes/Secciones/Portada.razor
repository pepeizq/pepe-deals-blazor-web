				}
			}

			excluirSteamIds?.Clear();

			if (string.IsNullOrEmpty(ocultarJuegosUsuarioSteamMinimos) == false)
			{
				if (ocultarJuegosUsuarioSteamMinimos == "checked" && excluirSteamIds?.Count == 0)
				{
					excluirSteamIds = juegosUsuario.Steam?.Select(j => j.Id).ToList();
				}
			}

            excluirGogIds?.Clear();

			if (string.IsNullOrEmpty(ocultarJuegosUsuarioGogMinimos) == false)
			{
				if (ocultarJuegosUsuarioGogMinimos == "checked" && excluirGogIds?.Count == 0)
				{
					excluirGogIds = juegosUsuario.Gog?.Select(j => j.Id).ToList();	
				}
			}

			if (tipoSeleccionadoMinimos == MinimosTipo.Nuevos)
			{
				if (fusionar == false)
				{
					juegosMinimosGestor = await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 0, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, minimoReseñasMinimos, excluirJuegosIds, excluirSteamIds, excluirGogIds);
				}
				else
				{
					juegosMinimosGestor.AddRange(await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 0, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, minimoReseñasMinimos, excluirJuegosIds, excluirSteamIds, excluirGogIds));
				}				
			}
			else if (tipoSeleccionadoMinimos == MinimosTipo.Populares)
			{
				if (fusionar == false)
				{
					juegosMinimosGestor = await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 1, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, minimoReseñasMinimos, excluirJuegosIds, excluirSteamIds, excluirGogIds);
				}
				else
				{
					juegosMinimosGestor.AddRange(await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 1, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, minimoReseñasMinimos, excluirJuegosIds, excluirSteamIds, excluirGogIds));
				}
			}
			else if (tipoSeleccionadoMinimos == MinimosTipo.Lanzamientos)
			{
				if (fusionar == false)
				{
					juegosMinimosGestor = await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 2, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, minimoReseñasMinimos, excluirJuegosIds, excluirSteamIds, excluirGogIds);
				}
				else
				{
					juegosMinimosGestor.AddRange(await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 2, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, minimoReseñasMinimos, excluirJuegosIds, excluirSteamIds, excluirGogIds));

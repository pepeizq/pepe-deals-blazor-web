		@{
			bool llegadoLimite = false;

			if (string.IsNullOrEmpty(usuarioId) == false)
			{
				if (usuarioPatreon == true || usuarioAdmin == true)
				{
					if (posicionJuegosMinimos > 950 && posicionJuegosMinimos <= 1000)
					{
						llegadoLimite = true;
					}
				}
				else
				{
					if (posicionJuegosMinimos > 450 && posicionJuegosMinimos <= 500)
					{
						llegadoLimite = true;
					}
				}
			}
			else
			{
				if (posicionJuegosMinimos > 150 && posicionJuegosMinimos <= 200)
				{
					llegadoLimite = true;
				}

		<div class="destacados-galeria-fila">
			@foreach (var destacado in juegosDestacadosMostrar)
			{
				if (destacado.Excluido == false)
				{
					bool mostrarBarra = false;
					string opacidad = string.Empty;

					if (destacadoActual != null)
					{
						if (destacado.Juego.IdMaestra == destacadoActual?.Juego?.IdMaestra)
						{
							opacidad = "opacity: 1;";
							mostrarBarra = true;
						}
					}


	private async Task<List<Juegos.Juego>> CargarJuegosDestacados(int cantidad = 6)
	{
		if (string.IsNullOrEmpty(ocultarJuegosUsuarioSteamDestacados) == false)
		{
			if (ocultarJuegosUsuarioSteamDestacados == "checked" && excluirSteamIds?.Count == 0)
			{
				excluirSteamIds = juegosUsuario.Steam?.Select(j => j.Id).ToList();
			}
		}

		bool ocultarBundles = true;

		if (string.IsNullOrEmpty(ocultarJuegosBundlesDestacados) == false)
		{
			if (ocultarJuegosBundlesDestacados == "checked")
			{
				ocultarBundles = true;
			}
			else
			{
				ocultarBundles = false;
			}
		}

		bool ocultarGratis = true;

		if (string.IsNullOrEmpty(ocultarJuegosGratisDestacados) == false)
		{
			if (ocultarJuegosGratisDestacados == "checked")
			{
				ocultarGratis = true;
			}
			else
			{
				ocultarGratis = false;
			}
		}

		bool ocultarSuscripciones = true;

		if (string.IsNullOrEmpty(ocultarJuegosSuscripcionesDestacados) == false)
		{
			if (ocultarJuegosSuscripcionesDestacados == "checked")
			{
				ocultarSuscripciones = true;
			}
			else
			{
				ocultarSuscripciones = false;
			}
		}

		return await BaseDatos.Portada.Buscar.Destacados(usuarioRegion, cantidad, minimoReseñasDestacados, excluirJuegosIds, excluirSteamIds, ocultarBundles, cantidadMesesOcultarBundlesDestacados, ocultarGratis, ocultarSuscripciones, cantidadMesesOcultarSuscripcionesDestacados);
	}

	private async Task CargarDestacados(bool vaciar)
	{
		if (juegosDestacadosMostrar == null || juegosDestacadosMostrar?.Count == 0)
		{
			if (vaciar == true)
			{
				juegosDestacadosMostrar?.Clear();
				await InvokeAsync(StateHasChanged);
			}

			List<Juegos.Juego> juegosDestacadosMostrar2 = await CargarJuegosDestacados(6);

			if (juegosDestacadosMostrar2?.Count > 0)
			{
				foreach (var juego in juegosDestacadosMostrar2)
				{
					JuegoMostrar juegoDestacadoMostrar = new JuegoMostrar
					{
						Juego = juego,
						DeseadoImportado = false,
						Color = "var(--fondoBotonPequeño)",
						DesplegableMostrar = true
					};

					JuegoDRM drmDestacados = JuegoDRM.NoEspecificado;

					if (usuarioRegion == TiendaRegion.Europa)
					{
						drmDestacados = juego.PrecioMinimosHistoricos[0].DRM;
					}
					else if (usuarioRegion == TiendaRegion.EstadosUnidos)
					{
						drmDestacados = juego.PrecioMinimosHistoricosUS[0].DRM;
					}

					if (Herramientas.UsuarioJuegos.ComprobarSiTiene(juegosUsuarioIndex, juego, drmDestacados) == true)
					{
						juegoDestacadoMostrar.Color = "var(--fondoBien)";
					}
					else
					{
						if (Herramientas.Deseados.ComprobarSiEstaImportado(deseadosImportadosIndex, juego, drmDestacados, true) == true)
						{
							juegoDestacadoMostrar.Color = "var(--fondoAlerta)";
							juegoDestacadoMostrar.DeseadoImportado = true;
						}
						if (Herramientas.Deseados.ComprobarSiEstaWeb(deseadosWebIndex, juego, drmDestacados, true) == true)
						{
							juegoDestacadoMostrar.Color = "var(--fondoAlerta)";
						}
					}

					if (juegosDestacadosMostrar == null)
					{
						juegosDestacadosMostrar = new List<JuegoMostrar>();
					}

					juegosDestacadosMostrar.Add(juegoDestacadoMostrar);
				}
			}

			if (juegosDestacadosMostrar?.Count > 0)
			{
				posicionMostrarDestacados = 0;
				videoDestacado = null;
			}
		}
	}

	private async Task CargarNoticias()
	{
		try
		{
			noticias = await BaseDatos.Noticias.Buscar.Actuales(tipoSeleccionadoNoticias, noticiasDias);

			if (noticias?.Count > 0)
			{
				foreach (Noticias.Noticia noticia in noticias)
				{
					bool añadirTipo = true;

					if (tiposActualesNoticias?.Count > 0)
					{
						foreach (var tipoActual in tiposActualesNoticias)
						{
							if (tipoActual == noticia.NoticiaTipo)
							{
								añadirTipo = false;
							}
						}
					}

					if (añadirTipo == true)
					{
						if (tiposActualesNoticias == null)
						{
							tiposActualesNoticias = new List<NoticiaTipo>();
						}

						tiposActualesNoticias.Add(noticia.NoticiaTipo);
					}
				}
			}

			if (string.IsNullOrEmpty(usuarioId) == false)
			{
				int limiteTiempoNoticias = 90;

				if (usuarioPatreon == true || usuarioAdmin == true)
				{
					limiteTiempoNoticias = 30;
				}

				CronometroNoticias(limiteTiempoNoticias);
			}
		}
		catch (Exception ex)
		{
			BaseDatos.Errores.Insertar.Mensaje("Portada Noticias", ex);
		}
	}

	private async Task CargarMinimos()
	{
		await FiltrarListaMinimos();

		if (string.IsNullOrEmpty(usuarioId) == false)
		{
			int limiteTiempoMinimos = 150;

			if (usuarioPatreon == true || usuarioAdmin == true)
			{
				limiteTiempoMinimos = 30;
			}

			CronometroMinimos(limiteTiempoMinimos);
		}
	}


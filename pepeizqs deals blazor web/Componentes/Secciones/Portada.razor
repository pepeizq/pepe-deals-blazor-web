@page "/"

@implements IAsyncDisposable

@using Juegos
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Noticias
@using Tiendas2
@using pepeizqs_deals_blazor_web.Componentes.Interfaz
@using pepeizqs_deals_web.Data
@using System.Text.Json

@inject IHttpContextAccessor Contexto
@inject IConfiguration Configuracion
@inject Servicios.Opciones ServicioOpciones

@{
	#nullable disable

	string patreon = Configuracion.GetValue<string>("RedesSociales:Patreon");
	string discord = Configuracion.GetValue<string>("RedesSociales:Discord");
	string telegram = Configuracion.GetValue<string>("RedesSociales:Telegram");
	string twitter = Configuracion.GetValue<string>("RedesSociales:Twitter");
	string steam = Configuracion.GetValue<string>("RedesSociales:Steam");
	string bluesky = Configuracion.GetValue<string>("RedesSociales:Bluesky");

	string contenidoJson = @"{
        ""@context"": ""https://schema.org"",
		""@type"": ""Organization"",
		""name"": ""pepe's deals"",
		""description"": ""@descripcion"",
        ""url"": ""https://@dominio/"",
        ""brand"": ""pepeizq's apps"",
		""logo"": {
			""@type"": ""ImageObject"",
			""logo"": ""https://@dominio/logo/logo6.png"",
			""caption"": ""pepe's deals logo"" },
		""contactPoint"": {
			""@type"": ""ContactPoint"",
			""contactType"": ""customer service"",
			""url"": ""https://@dominio/contact/"",
			""availableLanguage"": [ ""English"", ""Spanish"" ] },
		""sameAs"": [ ""@patreon"", ""@discord"", ""@telegram"", ""@twitter"", ""@steam"", ""@bluesky""]
	}";

	contenidoJson = contenidoJson.Replace("@dominio", dominio);
	contenidoJson = contenidoJson.Replace("@descripcion", Herramientas.Idiomas.BuscarTexto(idioma, "Subtitle", "Index"));
	contenidoJson = contenidoJson.Replace("@patreon", patreon);
	contenidoJson = contenidoJson.Replace("@discord", discord);
	contenidoJson = contenidoJson.Replace("@telegram", telegram);
	contenidoJson = contenidoJson.Replace("@twitter", twitter);
	contenidoJson = contenidoJson.Replace("@steam", steam);
	contenidoJson = contenidoJson.Replace("@bluesky", bluesky);

	<Titulo tipo="@Titulo.Tipo.Portada" idioma="@idioma" dominio="@dominio" contenidoJsonPortada="@contenidoJson"/>
}

@if (juegosDestacadosMostrar?.Count > 0)
{
	var destacadoActual = juegosDestacadosMostrar[posicionMostrarDestacados];

	@if (destacadoActual.Juego != null && destacadoActual.Excluido == false)
	{
		<div class="portada-espacio cuerpo-ancho">
			<a href="/game/@destacadoActual.Juego.IdMaestra.ToString()/@Herramientas.EnlaceAdaptador.Nombre(destacadoActual.Juego.Nombre)/" style="cursor: pointer; border: 0px; padding: 0px; display: block; width: 100%;">
				<div style="position: relative; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.28),0px 0px 1px 0px rgba(0, 0, 0, 0.24); background-color: @destacadoActual.Color;">
					<div class="destacado-mostrar" @onmouseover="@(e => EnseñarDestacadoVideo(e, destacadoActual?.Juego))">
						@if (string.IsNullOrEmpty(videoDestacado) == false)
						{
							<div class="destacado-fondo">
								<img src="@Herramientas.Ficheros.Imagenes.ServidorExterno(destacadoActual?.Juego?.Imagenes?.Library_1920x620, 1314, 424)" style="width: 100%;" alt="@destacadoActual?.Juego?.Nombre" fetchpriority="high">
							</div>

							<div class="destacado-video">
								<video onloadedmetadata="this.muted=true" playsinline autoplay loop muted>
									<source src="@videoDestacado" type="video/mp4" />
									<source src="@videoDestacado.Replace(".mp4", ".webm")" type="video/webm" />
								</video>
							</div>
						}
						else
						{
							<img src="@Herramientas.Ficheros.Imagenes.ServidorExterno(destacadoActual?.Juego?.Imagenes?.Library_1920x620, 1314, 424)" style="width: 100%; aspect-ratio: 96/31;" alt="@destacadoActual?.Juego?.Nombre" fetchpriority="high">
						}

						<div style="background-image: linear-gradient(to bottom, rgba(255,0,0,0), @destacadoActual?.Color);" class="destacado-hueco">

							<img src="@Herramientas.Ficheros.Imagenes.ServidorExterno(destacadoActual?.Juego?.Imagenes?.Logo)" class="destacado-logo-medidas" alt="@destacadoActual?.Juego?.Nombre" fetchpriority="high">

							<div style="display: flex; align-items: center; margin-bottom: 30px; color: var(--colorTexto); position: relative;">
								@if (usuarioRegion == TiendaRegion.Europa && destacadoActual?.Juego?.PrecioMinimosHistoricos?.Count > 0 ||
									 usuarioRegion == TiendaRegion.EstadosUnidos && destacadoActual?.Juego?.PrecioMinimosHistoricosUS?.Count > 0)
								{
									JuegoDRM drmDestacado = JuegoDRM.NoEspecificado;
									string tiendaComparar = string.Empty;
									string descuento = string.Empty;
									string precioMostrar = string.Empty;

									if (usuarioRegion == TiendaRegion.Europa)
									{
										drmDestacado = destacadoActual?.Juego?.PrecioMinimosHistoricos[0]?.DRM ?? JuegoDRM.NoEspecificado;
										tiendaComparar = destacadoActual?.Juego?.PrecioMinimosHistoricos[0]?.Tienda ?? "";
										descuento = destacadoActual?.Juego?.PrecioMinimosHistoricos[0]?.Descuento.ToString() ?? "";

										if (destacadoActual?.Juego?.PrecioMinimosHistoricos[0]?.PrecioCambiado > 0)
										{
											precioMostrar = Herramientas.Precios.Euro(destacadoActual.Juego.PrecioMinimosHistoricos?[0].PrecioCambiado);
										}
										else
										{
											precioMostrar = Herramientas.Precios.Euro(destacadoActual?.Juego?.PrecioMinimosHistoricos?[0].Precio);
										}
									}
									else if (usuarioRegion == TiendaRegion.EstadosUnidos)
									{
										drmDestacado = destacadoActual?.Juego?.PrecioMinimosHistoricosUS[0]?.DRM ?? JuegoDRM.NoEspecificado;
										tiendaComparar = destacadoActual?.Juego?.PrecioMinimosHistoricosUS[0]?.Tienda ?? "";
										descuento = destacadoActual?.Juego?.PrecioMinimosHistoricosUS[0]?.Descuento.ToString() ?? "";

										if (destacadoActual?.Juego?.PrecioMinimosHistoricosUS?[0].PrecioCambiado > 0)
										{
											precioMostrar = Herramientas.Precios.Dolar(destacadoActual.Juego.PrecioMinimosHistoricosUS?[0].PrecioCambiado);
										}
										else
										{
											precioMostrar = Herramientas.Precios.Dolar(destacadoActual?.Juego?.PrecioMinimosHistoricosUS?[0].Precio);
										}
									}

									string nombreTienda = string.Empty;
									string iconoTienda = string.Empty;
									List<Tiendas2.Tienda> tiendas = Tiendas2.TiendasCargar.GenerarListado();

									foreach (var tienda in tiendas)
									{
										if (tienda.Id == tiendaComparar)
										{
											nombreTienda = tienda.Nombre;
											iconoTienda = tienda.ImagenIcono;
											break;
										}
									}

									string iconoDRM = JuegoDRM2.SacarImagen(drmDestacado);
									string iconoDRM1 = iconoDRM.Replace(".webp", "-sm.webp");
									string iconoDRM2 = iconoDRM.Replace(".webp", "-md.webp");

									<div style="display: flex; margin-right: 20px;">
										<picture>
											<source srcset="@iconoDRM1 1x, @iconoDRM2 2x" type="image/webp">
											<img class="destacado-icono" src="@iconoDRM" alt="@JuegoDRM2.DevolverDRM(drmDestacado)" loading="lazy" />
										</picture>
									</div>

									string iconoTienda1 = iconoTienda.Replace(".webp", "-sm.webp");
									string iconoTienda2 = iconoTienda.Replace(".webp", "-md.webp");

									<div style="display: flex; margin-right: 40px;">
										<picture>
											<source srcset="@iconoTienda1 1x, @iconoTienda2 2x" type="image/webp">
											<img class="destacado-icono" src="@iconoTienda" alt="@nombreTienda" loading="lazy" />
										</picture>
									</div>

									<div class="destacado-sombra" style="display: flex; align-items: center;">
										<div class="destacado-precio-descuento" style="background-color: darkgreen;">
											@descuento%
										</div>
										<div class="destacado-precio-descuento" style="background-color: var(--fondoOscuro);">
											@precioMostrar
										</div>
									</div>

									@if (string.IsNullOrEmpty(usuarioId) == false && destacadoActual?.Color != "var(--fondoBien)" && destacadoActual?.DesplegableMostrar == true)
									{
										JuegoDRM drmDeseado = JuegoDRM.NoEspecificado;

										if (usuarioRegion == TiendaRegion.Europa)
										{
											drmDeseado = destacadoActual?.Juego?.PrecioMinimosHistoricos?[0].DRM ?? JuegoDRM.NoEspecificado;
										}
										else if (usuarioRegion == TiendaRegion.EstadosUnidos)
										{
											drmDeseado = destacadoActual?.Juego?.PrecioMinimosHistoricosUS?[0].DRM ?? JuegoDRM.NoEspecificado;
										}

										<div @onclick:preventDefault style="margin-left: 30px;"
											 @onmouseenter="@(e => AbrirDropdownHover("destacado", destacadoActual?.Juego?.Id ?? 0, drmDeseado))"
											 @onmouseleave="@(e => CerrarDropdownHover("destacado", destacadoActual?.Juego?.Id ?? 0, drmDeseado))">

											<button class="boton-pequeño" style="width: fit-content; padding: 10px; background-color: @destacadoActual?.Color;">
												<div class="svg-boton" style="display: flex;">
													<svg style="width: 34px; height: 34px; transform: rotate(@(dropdownAbierto == "destacado" + (destacadoActual?.Juego?.Id ?? 0).ToString() + "-" + ((int)drmDeseado).ToString() ? "0deg" : "180deg")); transition: transform 0.2s;"
														 xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
														<path d="M297.4 438.6C309.9 451.1 330.2 451.1 342.7 438.6L502.7 278.6C515.2 266.1 515.2 245.8 502.7 233.3C490.2 220.8 469.9 220.8 457.4 233.3L320 370.7L182.6 233.4C170.1 220.9 149.8 220.9 137.3 233.4C124.8 245.9 124.8 266.2 137.3 278.7L297.3 438.7z" />
													</svg>
												</div>
											</button>

											@if (dropdownAbierto == "destacado" + (destacadoActual?.Juego?.Id ?? 0).ToString() + "-" + ((int)drmDeseado).ToString())
											{
												<div @onclick:preventDefault
													 @onmouseenter="@(e => MantenerDropdownAbierto("destacado", destacadoActual?.Juego?.Id ?? 0, drmDeseado))"
													 @onmouseleave="@(e => CerrarAlSalirDelMenu("destacado", destacadoActual?.Juego?.Id ?? 0, drmDeseado))"
													 style="position: absolute; bottom: 55px; right: 0; background-color: @destacadoActual?.Color; border: 1px solid rgba(255, 255, 255, 0.1); box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); z-index: 1000; overflow: hidden; display: flex; flex-direction: column;">

													@if (destacadoActual?.DeseadoImportado == false)
													{
														<button @onclick="@(async e => { await CambiarEstadoDeseado(e, usuarioId, destacadoActual, drmDeseado); })"
																style="width: 100%; padding: 10px 15px; text-align: left; border: none; cursor: pointer; background-color: @destacadoActual?.Color; border-bottom: 1px solid rgba(255, 255, 255, 0.1); transition: background-color 0.2s;"
																onmouseover="this.style.backgroundColor='rgba(0, 0, 0, 0.2)'"
																onmouseout="this.style.backgroundColor='@destacadoActual?.Color'">
															<div style="display: flex; align-items: center; gap: 10px; justify-content: right;">
																<span style="color: var(--colorTexto); font-size: 16px;">
																	@if (destacadoActual?.Color == "var(--fondoAlerta)")
																	{
																		@Herramientas.Idiomas.BuscarTexto(idioma, "String13", "Index")
																	}
																	else
																	{
																		@Herramientas.Idiomas.BuscarTexto(idioma, "String12", "Index")
																	}
																</span>
																<div style="width: 20px; height: 20px; display: flex; fill: var(--colorTexto);">
																	@if (destacadoActual?.Color == "var(--fondoAlerta)")
																	{
																		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
																			<path d="M183.1 137.4C170.6 124.9 150.3 124.9 137.8 137.4C125.3 149.9 125.3 170.2 137.8 182.7L275.2 320L137.9 457.4C125.4 469.9 125.4 490.2 137.9 502.7C150.4 515.2 170.7 515.2 183.2 502.7L320.5 365.3L457.9 502.6C470.4 515.1 490.7 515.1 503.2 502.6C515.7 490.1 515.7 469.8 503.2 457.3L365.8 320L503.1 182.6C515.6 170.1 515.6 149.8 503.1 137.3C490.6 124.8 470.3 124.8 457.8 137.3L320.5 274.7L183.1 137.4z" />
																		</svg>
																	}
																	else
																	{
																		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
																			<path d="M341.5 45.1C337.4 37.1 329.1 32 320.1 32C311.1 32 302.8 37.1 298.7 45.1L225.1 189.3L65.2 214.7C56.3 216.1 48.9 222.4 46.1 231C43.3 239.6 45.6 249 51.9 255.4L166.3 369.9L141.1 529.8C139.7 538.7 143.4 547.7 150.7 553C158 558.3 167.6 559.1 175.7 555L320.1 481.6L464.4 555C472.4 559.1 482.1 558.3 489.4 553C496.7 547.7 500.4 538.8 499 529.8L473.7 369.9L588.1 255.4C594.5 249 596.7 239.6 593.9 231C591.1 222.4 583.8 216.1 574.8 214.7L415 189.3L341.5 45.1z" />
																		</svg>
																	}
																</div>
															</div>
														</button>
													}

													<button @onclick="@(async e => { await ExcluirJuego(e, "destacado", usuarioId, destacadoActual); })"
															style="width: 100%; padding: 10px 15px; text-align: left; border: none; cursor: pointer; border-bottom: 1px solid var(--fondoCodigo); background-color: var(--fondoBotonPequeño); transition: background-color 0.2s;"
															onmouseover="this.style.backgroundColor='var(--fondoBotonPequeñoHover)'"
															onmouseout="this.style.backgroundColor='var(--fondoBotonPequeño)'">
														<div style="display: flex; align-items: center; gap: 10px; justify-content: right;">
															<span style="color: var(--colorTexto); font-size: 16px;">
																@Herramientas.Idiomas.BuscarTexto(idioma, "String16", "Index")
															</span>
															<div style="width: 20px; height: 20px; display: flex; fill: var(--colorTexto);">
																<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
																	<path d="M431.2 476.5L163.5 208.8C141.1 240.2 128 278.6 128 320C128 426 214 512 320 512C361.5 512 399.9 498.9 431.2 476.5zM476.5 431.2C498.9 399.8 512 361.4 512 320C512 214 426 128 320 128C278.5 128 240.1 141.1 208.8 163.5L476.5 431.2zM64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320z" />
																</svg>
															</div>
														</div>
													</button>
												</div>
											}
										</div>
									}
								}
							</div>
						</div>
					</div>
				</div>
			</a>

			<div class="destacados-galeria-fila">
				@foreach (var destacado in juegosDestacadosMostrar)
				{
					if (destacado.Excluido == false)
					{
						bool mostrarBarra = false;
						string opacidad = string.Empty;

						if (destacadoActual != null)
						{
							if (destacado.Juego.IdMaestra == destacadoActual?.Juego?.IdMaestra)
							{
								opacidad = "opacity: 1;";
								mostrarBarra = true;
							}
						}

						<div class="destacados-galeria-columna" @onclick="@(e => CambiarJuegoDestacado(e, destacado))" style="background-color: @destacado.Color;">
							<img @key="destacado.Juego.Id.ToString()" class="destacados-galeria-captura @(mostrarBarra ? "activo" : "")" src="@Herramientas.Ficheros.Imagenes.ServidorExterno(destacado.Juego.Imagenes.Header_460x215, 214, 100)" width="460" height="215" style="@opacidad" alt="@destacado.Juego.Nombre">

							@if (mostrarBarra == true)
							{
								<div class="destacado-barra-contenedor">
									<div class="destacado-progreso" style="filter: brightness(150%); background: color-mix(in srgb, var(--fondoCodigo), @destacado.Color 50%);" />
								</div>
							}
						</div>
					}
				}
			</div>
		</div>
	}
}
else
{
	<div class="portada-espacio cuerpo-ancho">
		<img src="/imagenes/otros/portada-placeholder.webp" style="width: 100%; aspect-ratio: 96/31;" fetchpriority="high" alt="Placeholder" />
	
		<div class="destacados-galeria-fila" style="visibility: hidden; min-height: 100px;">
		</div>
	</div>
}

@if (noticias?.Count > 0)
{
	<div class="caja-portada-noticias" style="padding: 30px; background-color: var(--fondoPortadaNoticias2); border-top: 1px solid var(--bordePortadaNoticias); border-bottom: 1px solid var(--bordePortadaNoticias);">
		<div style="display: flex; align-items: center; justify-content: center; transition: transform 0.3s ease, opacity 0.3s ease; flex-wrap: wrap;">
			<div class="caja-portada" style="background-color: var(--fondoPortadaNoticias); border: 2px solid var(--bordePortadaNoticias);">
				<button @onclick="@(e => CambiarTipo(e, Noticias.NoticiaTipo.Desconocido))" class="boton-portada" style="@CambiarEstilo(Noticias.NoticiaTipo.Desconocido) border: 0px; height: 50px; padding: 15px 25px; display: inline-flex; align-items: center; color: var(--colorTexto); border-radius: inherit;">
					<div>
						<h1 style="font-size: 17px; margin: 0px;">
							@Herramientas.Idiomas.BuscarTexto(idioma, "String2", "Index")
						</h1>
					</div>
				</button>

				@if (tiposActualesNoticias?.Count > 1 && Herramientas.Bots.UserAgentEsBot(userAgent) == false)
				{
					tiposActualesNoticias = tiposActualesNoticias.OrderBy(x => Noticias.NoticiasCargar.Traduccion(x, idioma)).ToList();

					foreach (var tipo in tiposActualesNoticias)
					{
						if (tipo != NoticiaTipo.Desconocido)
						{
							<button @onclick="@(e => CambiarTipo(e, tipo))" class="boton-portada" style="@CambiarEstilo(tipo) border: 0px; height: 50px; padding: 15px 25px; display: inline-flex; align-items: center; color: var(--colorTexto); border-radius: inherit;">
								<div style="font-size: 17px;">
									@Noticias.NoticiasCargar.Traduccion(tipo, idioma)
								</div>
							</button>
						}
					}
				}
			</div>
		</div>

		<div class="cuerpo-ancho" style="display: flex; flex-direction: column; @(noticias.Count > 3 ? "margin-top: 30px;" : "margin-top: 20px;")">
			<div style="display: flex; gap: 35px; overflow-x: auto; flex-wrap: nowrap; height: 100%; scrollbar-color: var(--fondoCodigo) var(--fondoOscuro); overflow-y: hidden; justify-content: space-around; width: fit-content; margin-left: auto; margin-right: auto; max-width:100%; @(noticias.Count > 3 ? "padding: 10px 10px 20px 10px;" : "padding: 10px;")" title="@Herramientas.Idiomas.BuscarTexto(idioma, "String1", "Index")">
				@foreach (var noticia in noticias)
				{
					<CajaNoticia idioma="@idioma" noticia="@noticia" tipo="@CajaNoticia.Tipo.Portada" />
				}
			</div>

			<div style="display: flex; align-items: center; gap: 50px; justify-content: center; margin-top: 20px;">
				<a class="boton-pequeño" style="padding: 15px 30px; width: fit-content;" href="/last-news">
					@Herramientas.Idiomas.BuscarTexto(idioma, "String4", "Index")
				</a>

				<RedesSociales region="@usuarioRegion" idioma="@idioma" />
			</div>
		</div>
	</div>
}
else
{
	<div style="margin-top: 40px; padding: 30px; background-color: var(--fondoPortadaNoticias2); display: flex; align-items: center; gap: 50px; justify-content: center;">
		<a class="boton-pequeño" style="padding: 15px 30px; width: fit-content;" href="/last-news">
			@Herramientas.Idiomas.BuscarTexto(idioma, "String4", "Index")
		</a>

		<RedesSociales idioma="@idioma" />
	</div>
}

@if (juegosMinimosMostrar?.Count > 0)
{
	<div style="display: flex; align-items: center; justify-content: center; margin-top: 40px; transition: transform 0.3s ease, opacity 0.3s ease;">
		<div class="caja-portada">
			<button @onclick="@(e => CambiarTipo(e, MinimosTipo.Nuevos))" class="boton-portada" style="@CambiarEstilo(MinimosTipo.Nuevos) border: 0px; height: 50px; padding: 15px 25px; display: inline-flex; align-items: center; color: var(--colorTexto); border-radius: inherit;">
				<div style="font-size: 17px;">
					@CambiarTexto(MinimosTipo.Nuevos, Herramientas.Idiomas.BuscarTexto(idioma, "String3", "Index"))
				</div>
			</button>

			@if (Herramientas.Bots.UserAgentEsBot(userAgent) == false)
			{
				<button @onclick="@(e => CambiarTipo(e, MinimosTipo.Populares))" class="boton-portada" style="@CambiarEstilo(MinimosTipo.Populares) border: 0px; height: 50px; padding: 15px 25px; display: inline-flex; align-items: center; color: var(--colorTexto); border-radius: inherit;">
					<div style="font-size: 17px;">
						@CambiarTexto(MinimosTipo.Populares, Herramientas.Idiomas.BuscarTexto(idioma, "String5", "Index"))
					</div>
				</button>

				<button @onclick="@(e => CambiarTipo(e, MinimosTipo.Lanzamientos))" class="boton-portada" style="@CambiarEstilo(MinimosTipo.Lanzamientos) border: 0px; height: 50px; padding: 15px 25px; display: inline-flex; align-items: center; color: var(--colorTexto); border-radius: inherit;">
					<div style="font-size: 17px;">
						@CambiarTexto(MinimosTipo.Lanzamientos, Herramientas.Idiomas.BuscarTexto(idioma, "String7", "Index"))
					</div>
				</button>


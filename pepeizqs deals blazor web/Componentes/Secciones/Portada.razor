								@if (usuarioRegion == TiendaRegion.Europa && destacadoActual?.Juego?.PrecioMinimosHistoricos?.Count > 0 ||
									 usuarioRegion == TiendaRegion.EstadosUnidos && destacadoActual?.Juego?.PrecioMinimosHistoricosUS?.Count > 0)
								{
									JuegoDRM drmDestacado = JuegoDRM.NoEspecificado;
									string tiendaComparar = string.Empty;
									string descuento = string.Empty;
									string precioMostrar = string.Empty;

									if (usuarioRegion == TiendaRegion.Europa)
									{
										drmDestacado = destacadoActual?.Juego?.PrecioMinimosHistoricos[0]?.DRM ?? JuegoDRM.NoEspecificado;
										tiendaComparar = destacadoActual?.Juego?.PrecioMinimosHistoricos[0]?.Tienda ?? "";
										descuento = destacadoActual?.Juego?.PrecioMinimosHistoricos[0]?.Descuento.ToString() ?? "";
									
										if (destacadoActual?.Juego?.PrecioMinimosHistoricos[0]?.PrecioCambiado > 0)
										{
											precioMostrar = Herramientas.Precios.Euro(destacadoActual.Juego.PrecioMinimosHistoricos?[0].PrecioCambiado);
										}
										else
										{
											precioMostrar = Herramientas.Precios.Euro(destacadoActual?.Juego?.PrecioMinimosHistoricos?[0].Precio);
										}
									}
									else if (usuarioRegion == TiendaRegion.EstadosUnidos)
									{
										drmDestacado = destacadoActual?.Juego?.PrecioMinimosHistoricosUS[0]?.DRM ?? JuegoDRM.NoEspecificado;
										tiendaComparar = destacadoActual?.Juego?.PrecioMinimosHistoricosUS[0]?.Tienda ?? "";
										descuento = destacadoActual?.Juego?.PrecioMinimosHistoricosUS[0]?.Descuento.ToString() ?? "";
									
										if (destacadoActual?.Juego?.PrecioMinimosHistoricosUS?[0].PrecioCambiado > 0)
										{
											precioMostrar = Herramientas.Precios.Dolar(destacadoActual.Juego.PrecioMinimosHistoricosUS?[0].PrecioCambiado);
										}
										else
										{
											precioMostrar = Herramientas.Precios.Dolar(destacadoActual?.Juego?.PrecioMinimosHistoricosUS?[0].Precio);
										}
									}

									string nombreTienda = string.Empty;
									string iconoTienda = string.Empty;
									List<Tiendas2.Tienda> tiendas = Tiendas2.TiendasCargar.GenerarListado();

									foreach (var tienda in tiendas)
									{
										if (tienda.Id == tiendaComparar)
										{
											nombreTienda = tienda.Nombre;
											iconoTienda = tienda.ImagenIcono;
											break;
										}
									}

									string iconoDRM = JuegoDRM2.SacarImagen(drmDestacado);
									string iconoDRM1 = iconoDRM.Replace(".webp", "-sm.webp");
									string iconoDRM2 = iconoDRM.Replace(".webp", "-md.webp");

									<div style="display: flex; margin-right: 20px;">

			<div style="display: flex; align-items: center; gap: 50px; justify-content: center; margin-top: 20px;">
				<a class="boton-pequeño" style="padding: 15px 30px; width: fit-content;" href="/last-news">
					@Herramientas.Idiomas.BuscarTexto(idioma, "String4", "Index")
				</a>

				<RedesSociales idioma="@idioma" />
			</div>
		</div>
	</div>
}
else
{
	<div style="margin-top: 40px; padding: 30px; background-color: var(--fondoPortadaNoticias2); display: flex; align-items: center; gap: 50px; justify-content: center;">
		<a class="boton-pequeño" style="padding: 15px 30px; width: fit-content;" href="/last-news">
			@Herramientas.Idiomas.BuscarTexto(idioma, "String4", "Index")
		</a>

		<RedesSociales idioma="@idioma" />
	</div>
}


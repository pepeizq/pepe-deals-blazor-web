	[PersistentState] public List<Juegos.Juego> juegosMinimosGestor { get; set; }
	[PersistentState] public List<JuegoMostrar> juegosMinimosMostrar { get; set; }
	private MinimosTipo tipoSeleccionadoMinimos = MinimosTipo.Nuevos;

	private enum MinimosTipo
	{
		Nuevos,
		Populares,
		Lanzamientos,
		Proximamente
	}

	private async Task FiltrarListaMinimos(bool fusionar = false)
	{
		await GenerarListaMinimos(fusionar);

		if (juegosMinimosGestor?.Count > 0)
		{
			List<JuegoMostrar> listaMostrar = new List<JuegoMostrar>();

			foreach (var juego in juegosMinimosGestor)
			{
				JuegoDRM drmGestor = JuegoDRM.NoEspecificado;

				if (usuarioRegion == TiendaRegion.Europa)
				{
					if (juego.PrecioMinimosHistoricos?.Count > 0)
					{
						drmGestor = juego.PrecioMinimosHistoricos[0].DRM;
					}
				}
				else if (usuarioRegion == TiendaRegion.EstadosUnidos)
				{
					if (juego.PrecioMinimosHistoricosUS?.Count > 0)
					{
						drmGestor = juego.PrecioMinimosHistoricosUS[0].DRM;
					}
				}

				if (juegosMinimosMostrar == null)
				{
					juegosMinimosMostrar = new List<JuegoMostrar>();
				}

				JuegoMostrar juegoMinimoMostrar = new JuegoMostrar
				{
					Juego = juego,
					DeseadoImportado = false,
					Color = "var(--fondoBotonPequeño)",
					DesplegableMostrar = false
				};

				if (string.IsNullOrEmpty(usuarioId) == false)
				{
					if (usuarioRegion == TiendaRegion.Europa && juego.PrecioMinimosHistoricos?.Count > 0 ||
						usuarioRegion == TiendaRegion.EstadosUnidos && juego.PrecioMinimosHistoricosUS?.Count > 0)
					{
						if (Herramientas.UsuarioJuegos.ComprobarSiTiene(juegosUsuarioIndex, juego, drmGestor) == true)
						{
							juegoMinimoMostrar.Color = "var(--fondoBien)";
						}
						else
						{
							if (Herramientas.Deseados.ComprobarSiEstaImportado(deseadosImportadosIndex, juego, drmGestor, true) == true)
							{
								juegoMinimoMostrar.Color = "var(--fondoAlerta)";
								juegoMinimoMostrar.DeseadoImportado = true;
							}

							if (Herramientas.Deseados.ComprobarSiEstaWeb(deseadosWebIndex, juego, drmGestor, true) == true)
							{
								juegoMinimoMostrar.Color = "var(--fondoAlerta)";
							}
						}
					}
				}

				listaMostrar.Add(juegoMinimoMostrar);
			}

			juegosMinimosMostrar = listaMostrar;
		}
	}


				<AuthorizeView>
					<Authorized>
						<div style="display: flex; flex-direction: column; gap: 30px; border-radius: 10px; background-color: var(--fondoSubsubcabecera); box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.1),0px 0px 2px 0px rgba(0, 0, 0, 0.1); padding: 20px;">
							<div style="display: flex; align-items: center; gap: 20px;">
								<div class="checkbox-caja">
									<input type="checkbox" class="checkbox-interior" checked="@ocultarJuegosUsuarioSteam" @onchange="OcultarJuegosUsuarioSteam">
								</div>

								<div>
									@Herramientas.Idiomas.BuscarTexto(idioma, "FilterOption1", "Index")
								</div>
							</div>

							<div style="display: flex; align-items: center; gap: 20px;">
								<div class="checkbox-caja">
									<input type="checkbox" class="checkbox-interior" checked="@ocultarJuegosUsuarioGog" @onchange="OcultarJuegosUsuarioGog">
								</div>

								<div>
									@Herramientas.Idiomas.BuscarTexto(idioma, "FilterOption4", "Index")
								</div>
							</div>
						</div>
					</Authorized>
				</AuthorizeView>

				<div style="background-color: var(--fondoSubsubcabecera); border-radius: 10px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.1),0px 0px 2px 0px rgba(0, 0, 0, 0.1);">
					<div style="display: flex; align-items: center; gap: 30px; padding: 10px 20px; background: color-mix(in srgb, var(--fondoSubcabecera) 55%, var(--fondoBotonPequeño)); border-top-left-radius: inherit; border-top-right-radius: inherit;">
						@Herramientas.Idiomas.BuscarTexto(idioma, "FilterOption2", "Index")
					</div>

					<div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; padding: 20px;">
						@foreach (var drm in drms)
						{
							string iconoDRM = string.Empty;
							string nombreDRM = string.Empty;

							foreach (var drm2 in JuegoDRM2.GenerarListado())
							{
								if (drm2.Id == drm.DRMId)
								{
									iconoDRM = drm2.Imagen;
									nombreDRM = drm2.Nombre;
								}
							}

							<div style="display: flex; align-items: center;" title="@nombreDRM">
								<div class="checkbox-caja">
									<input type="checkbox" class="checkbox-interior" checked="@drm.Checkbox" @onchange="@(e => EnseñarJuegosDRM(e, drm.DRMId))">
								</div>

								@if (drm.DRMId != JuegoDRM.DRMFree)
								{
									<div style="margin-left: 20px;">
										<img src="@Herramientas.Ficheros.Imagenes.ServidorExterno(iconoDRM)" style="max-width: 24px; max-height: 24px;" title="@nombreDRM"  />
									</div>
								}
								else
								{
									<div style="margin-left: 20px;">
										<label style="font-size: 10px; max-width: 24px; text-align: center;">@nombreDRM</label>
									</div>
								}
							</div>
						}
					</div>
				</div>

				<div style="background-color: var(--fondoSubsubcabecera); border-radius: 10px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.1),0px 0px 2px 0px rgba(0, 0, 0, 0.1);">
					<div style="display: flex; align-items: center; gap: 30px; padding: 10px 20px; background: color-mix(in srgb, var(--fondoSubcabecera) 55%, var(--fondoBotonPequeño)); border-top-left-radius: inherit; border-top-right-radius: inherit;">
						@Herramientas.Idiomas.BuscarTexto(idioma, "FilterOption3", "Index")
					</div>

					<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; padding: 20px;">
						@foreach (var categoria in categorias)
						{
							string nombreCategoria = string.Empty;

							if (categoria.Categoria == JuegoTipo.Game)
							{
								nombreCategoria = Herramientas.Idiomas.BuscarTexto(idioma, "FilterOption3.1", "Index");
							}
							else if (categoria.Categoria == JuegoTipo.DLC)
							{
								nombreCategoria = Herramientas.Idiomas.BuscarTexto(idioma, "FilterOption3.2", "Index");
							}
							else if (categoria.Categoria == JuegoTipo.Music)
							{
								nombreCategoria = Herramientas.Idiomas.BuscarTexto(idioma, "FilterOption3.3", "Index");
							}
							else if (categoria.Categoria == JuegoTipo.Software)
							{
								nombreCategoria = Herramientas.Idiomas.BuscarTexto(idioma, "FilterOption3.4", "Index");
							}

							<div style="display: flex; align-items: center;" title="@nombreCategoria">
								<div class="checkbox-caja">
									<input type="checkbox" class="checkbox-interior" checked="@categoria.Checkbox" @onchange="@(e => EnseñarJuegosCategoria(e, categoria.Categoria))">
								</div>

								<div style="margin-left: 15px;">
									<label style="font-size: 14px;">@nombreCategoria</label>
								</div>
							</div>
						}
					</div>
				</div>
			</div>
		</div>
	</div>
}

@code {

	#nullable disable

	private string idioma = "en";
	private string usuarioId = null;
	private string userAgent = null;
	private string dominio = null;

	[PersistentState] public Herramientas.UsuarioListadosJuegos juegosUsuario { get; set; }
	[PersistentState] public Herramientas.UsuarioJuegosIndex juegosUsuarioIndex { get; set; }

	[PersistentState] public Usuario deseadosUsuario { get; set; }
	[PersistentState] public Herramientas.UsuarioDeseadosImportadosIndex deseadosImportadosIndex { get; set; }
	[PersistentState] public Herramientas.UsuarioDeseadosWebIndex deseadosWebIndex { get; set; }

	private List<int> excluirJuegosIds = new List<int>();
	private List<int> excluirSteamIds = new List<int>();
	private List<int> excluirGogIds = new List<int>();

	private bool usuarioPatreon = false;
	private bool usuarioAdmin = false;
	private TiendaRegion usuarioRegion = TiendaRegion.Europa;

	private string videoDestacado = string.Empty;

	protected override async Task OnInitializedAsync()
	{
		Herramientas.ContextoUsuarioDatos datos = Herramientas.ContextoUsuario.Leer(Contexto);
		idioma = datos.Idioma;
		usuarioId = datos.UsuarioId;
		userAgent = datos.UserAgent;
		dominio = datos.Dominio;
		usuarioRegion = datos.Region;

		if (string.IsNullOrEmpty(usuarioId) == false)
		{
			Task<string> tareaIdioma = BaseDatos.Usuarios.Buscar.IdiomaSobreescribir(usuarioId);
			Task<Herramientas.UsuarioListadosJuegos> tareaJuegos = Herramientas.UsuarioJuegos.Cargar(usuarioId);
			Task<Usuario> tareaDeseados = BaseDatos.Usuarios.Buscar.DeseadosTiene(usuarioId);
			Task<DateTime?> tareaPatreon = BaseDatos.Usuarios.Buscar.FechaPatreon(usuarioId);
			Task<bool> tareaAdmin = BaseDatos.Usuarios.Buscar.RolDios(usuarioId);
			Task<int> tareaRegion = BaseDatos.Usuarios.Buscar.OpcionInt(usuarioId, "Currency");
			Task<string> tareaIdiomaJuego = BaseDatos.Usuarios.Buscar.IdiomaJuegos(usuarioId);

			await Task.WhenAll(tareaIdioma, tareaJuegos, tareaDeseados, tareaPatreon, tareaAdmin, tareaRegion, tareaIdiomaJuego);

			idioma = tareaIdioma.Result;
			juegosUsuario = tareaJuegos.Result;
			deseadosUsuario = tareaDeseados.Result;
			usuarioPatreon = Herramientas.Patreon.VerificarActivo(tareaPatreon.Result);
			usuarioAdmin = tareaAdmin.Result;
			usuarioRegion = (TiendaRegion)tareaRegion.Result;

			juegosUsuarioIndex = Herramientas.UsuarioJuegos.CrearIndex(juegosUsuario);
			excluirJuegosIds = juegosUsuarioIndex.Excluidos.ToList();
			deseadosImportadosIndex = Herramientas.Deseados.CrearImportadosIndex(deseadosUsuario);
			deseadosWebIndex = Herramientas.Deseados.CrearWebIndex(deseadosUsuario);

			Usuario opciones = await BaseDatos.Usuarios.Buscar.OpcionesPortada(usuarioId);

			if (opciones != null)
			{
				if (opciones.Currency.HasValue == true)
				{
					usuarioRegion = (TiendaRegion)opciones.Currency.Value;		
				}

				#region Filtrado

				if (opciones.IndexOption1 == true)
				{
					ocultarJuegosUsuarioSteam = "checked";
				}
				else
				{
					ocultarJuegosUsuarioSteam = null;
				}

				if (opciones.IndexOption2 == true)
				{
					ocultarJuegosUsuarioGog = "checked";
				}
				else
				{
					ocultarJuegosUsuarioGog = null;
				}

				if (string.IsNullOrEmpty(opciones.IndexDRMs) == false)
				{
					drms = JsonSerializer.Deserialize<List<MostrarJuegoDRM>>(opciones.IndexDRMs);

					if (drms?.Count > 0)
					{
						foreach (var drm2 in JuegoDRM2.GenerarListado())
						{
							bool existe = false;

							foreach (var drm in drms)
							{
								if (drm.DRMId == drm2.Id)
								{
									existe = true;
									break;
								}
							}

							if (existe == false)
							{
								drms.Add(new MostrarJuegoDRM
								{
									DRMId = drm2.Id,
									Estado = false,
									Checkbox = null
								});
							}
						}
					}
				}

				if (string.IsNullOrEmpty(opciones.IndexCategories) == false)
				{
					categorias = JsonSerializer.Deserialize<List<MostrarJuegoCategoria>>(opciones.IndexCategories);
				}

				#endregion
			}
		}

		//------------------------------------------------

		Task tareaDestacados = CargarDestacados();
		Task tareaNoticias = CargarNoticias();
		Task tareaMinimos = CargarMinimos();

		await Task.WhenAll(tareaDestacados, tareaNoticias, tareaMinimos);
	}

	protected override async Task OnAfterRenderAsync(bool primerRender)
	{
		if (primerRender == true)
		{

		}
	}

	#region Inicio 

	private async Task CargarDestacados()
	{
		if (juegosDestacadosMostrar == null || juegosDestacadosMostrar?.Count == 0)
		{
			if (string.IsNullOrEmpty(ocultarJuegosUsuarioSteam) == false)
			{
				if (ocultarJuegosUsuarioSteam == "checked" && excluirSteamIds?.Count == 0)
				{
					excluirSteamIds = juegosUsuario.Steam.Select(j => j.Id).ToList();
				}
			}

			List<Juegos.Juego> juegosDestacadosMostrar2 = await BaseDatos.Portada.Buscar.Destacados(usuarioRegion, 6, excluirJuegosIds, excluirSteamIds);

			if (juegosDestacadosMostrar2?.Count > 0)
			{
				foreach (var juego in juegosDestacadosMostrar2)
				{
					JuegoMostrar juegoDestacadoMostrar = new JuegoMostrar
					{
						Juego = juego,
						DeseadoImportado = false,
						Color = "var(--fondoBotonPequeño)",
						DesplegableMostrar = true
					};

					JuegoDRM drmDestacados = JuegoDRM.NoEspecificado;

					if (usuarioRegion == TiendaRegion.Europa)
					{
						drmDestacados = juego.PrecioMinimosHistoricos[0].DRM;
					}
					else if (usuarioRegion == TiendaRegion.EstadosUnidos)
					{
						drmDestacados = juego.PrecioMinimosHistoricosUS[0].DRM;
					}

					if (Herramientas.UsuarioJuegos.ComprobarSiTiene(juegosUsuarioIndex, juego, drmDestacados) == true)
					{
						juegoDestacadoMostrar.Color = "var(--fondoBien)";
					}
					else
					{
						if (Herramientas.Deseados.ComprobarSiEstaImportado(deseadosImportadosIndex, juego, drmDestacados, true) == true)
						{
							juegoDestacadoMostrar.Color = "var(--fondoAlerta)";
							juegoDestacadoMostrar.DeseadoImportado = true;
						}
						if (Herramientas.Deseados.ComprobarSiEstaWeb(deseadosWebIndex, juego, drmDestacados, true) == true)
						{
							juegoDestacadoMostrar.Color = "var(--fondoAlerta)";
						}
					}

					if (juegosDestacadosMostrar == null)
					{
						juegosDestacadosMostrar = new List<JuegoMostrar>();
					}

					juegosDestacadosMostrar.Add(juegoDestacadoMostrar);
				}
			}

			if (juegosDestacadosMostrar?.Count > 0)
			{
				posicionMostrarDestacados = 0;
				videoDestacado = null;
			}
		}

		CronometroDestacados();
	}

	private async Task CargarNoticias()
	{
		try
		{
			noticias ??= await BaseDatos.Noticias.Buscar.Actuales(tipoSeleccionadoNoticias, 3);

			if (noticias?.Count > 0)
			{
				foreach (var noticia in noticias)
				{
					bool añadirTipo = true;

					if (tiposActualesNoticias?.Count > 0)
					{
						foreach (var tipoActual in tiposActualesNoticias)
						{
							if (tipoActual == noticia.NoticiaTipo)
							{
								añadirTipo = false;
							}
						}
					}

					if (añadirTipo == true)
					{
						if (tiposActualesNoticias == null)
						{
							tiposActualesNoticias = new List<NoticiaTipo>();
						}

						tiposActualesNoticias.Add(noticia.NoticiaTipo);
					}
				}
			}

			if (string.IsNullOrEmpty(usuarioId) == false)
			{
				int limiteTiempoNoticias = 90;

				if (usuarioPatreon == true || usuarioAdmin == true)
				{
					limiteTiempoNoticias = 30;
				}

				CronometroNoticias(limiteTiempoNoticias);
			}
		}
		catch (Exception ex)
		{
			BaseDatos.Errores.Insertar.Mensaje("Portada Noticias", ex);
		}
	}


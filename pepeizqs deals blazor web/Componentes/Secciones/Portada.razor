	#region Minimos Lista

	private int posicionJuegosMinimos = 0;
	private bool cargandoMasMinimos = false;

	private async Task GenerarListaMinimos(bool fusionar = false)
	{
		try
		{
			List<string> categoriasNumeros = new List<string>();

			if (categorias?.Count > 0)
			{
				foreach (var categoria in categorias)
				{
					if (categoria.Estado == true)
					{
						categoriasNumeros.Add(Convert.ChangeType(categoria.Categoria, categoria.Categoria.GetTypeCode()).ToString());
					}
				}
			}

			List<string> drmsNumeros = new List<string>();

			if (drms?.Count > 0)
			{
				foreach (var drm in drms)
				{
					if (drm.Estado == true)
					{
						drmsNumeros.Add(Convert.ChangeType(drm.DRMId, drm.DRMId.GetTypeCode()).ToString());
					}
				}
			}

			if (string.IsNullOrEmpty(ocultarJuegosUsuarioSteam) == false)
			{
				if (ocultarJuegosUsuarioSteam == "checked" && excluirSteamIds?.Count == 0)
				{
					excluirSteamIds = juegosUsuario.Steam.Select(j => j.Id).ToList();
				}
			}

			if (string.IsNullOrEmpty(ocultarJuegosUsuarioGog) == false)
			{
				if (ocultarJuegosUsuarioGog == "checked" && excluirGogIds?.Count == 0)
				{
					excluirGogIds = juegosUsuario.Gog.Select(j => j.Id).ToList();	
				}
			}

			if (tipoSeleccionadoMinimos == MinimosTipo.Nuevos)
			{
				if (fusionar == false)
				{
					juegosMinimosGestor = await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 0, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, 199, excluirJuegosIds, excluirSteamIds, excluirGogIds);
				}
				else
				{
					juegosMinimosGestor.AddRange(await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 0, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, 199, excluirJuegosIds, excluirSteamIds, excluirGogIds));
				}				
			}
			else if (tipoSeleccionadoMinimos == MinimosTipo.Populares)
			{
				if (fusionar == false)
				{
					juegosMinimosGestor = await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 1, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, 199, excluirJuegosIds, excluirSteamIds, excluirGogIds);
				}
				else
				{
					juegosMinimosGestor.AddRange(await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 1, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, 199, excluirJuegosIds, excluirSteamIds, excluirGogIds));
				}
			}
			else if (tipoSeleccionadoMinimos == MinimosTipo.Lanzamientos)
			{
				if (fusionar == false)
				{
					juegosMinimosGestor = await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 2, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, 29, excluirJuegosIds, excluirSteamIds, excluirGogIds);
				}
				else
				{
					juegosMinimosGestor.AddRange(await BaseDatos.Portada.Buscar.Minimos(usuarioRegion, 2, posicionJuegosMinimos, categoriasNumeros, drmsNumeros, 29, excluirJuegosIds, excluirSteamIds, excluirGogIds));
				}
			}
			else if (tipoSeleccionadoMinimos == MinimosTipo.Proximamente)
			{
				juegosMinimosGestor = await BaseDatos.Portada.Buscar.Proximamente(50, categoriasNumeros, drmsNumeros);
			}
		}
		catch (Exception ex)
		{
			BaseDatos.Errores.Insertar.Mensaje("Portada Minimos", ex);
		}
	}

	private async Task CargarMasMinimos()
	{
		cargandoMasMinimos = true;

		posicionJuegosMinimos = posicionJuegosMinimos + 100;

		await Filtros(true);

		cargandoMasMinimos = false;
	}

	private PeriodicTimer cronometroMinimos = null;
	private int cronometroMinimosContador = 0;

	private async void CronometroMinimos(int limite)
	{
		cronometroMinimos = new PeriodicTimer(TimeSpan.FromSeconds(10));

		while (await cronometroMinimos.WaitForNextTickAsync())
		{
			cronometroMinimosContador += 1;

			if (cronometroMinimosContador >= limite)
			{
				await Filtros();

				cronometroMinimosContador = 0;
			}

			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task CambiarTipo(MouseEventArgs e, MinimosTipo nuevoTipo)
	{
		tipoSeleccionadoMinimos = nuevoTipo;

		await Filtros();
	}

	private string CambiarEstilo(MinimosTipo nuevoTipo)
	{
		if (nuevoTipo != tipoSeleccionadoMinimos)
		{
			return "background-color: transparent;";
		}
		else
		{
			return "background-color: var(--botonSeleccionado);";
		}
	}

	private string CambiarTexto(MinimosTipo nuevoTipo, string texto)
	{
		if (nuevoTipo == tipoSeleccionadoMinimos)
		{
			return string.Format("{0} {1}", Herramientas.Idiomas.BuscarTexto(idioma, "String6", "Index"), texto);
		}
		else
		{
			return texto;
		}

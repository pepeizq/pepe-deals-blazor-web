	{
		List<MostrarJuegoCategoria> nuevaLista = new List<MostrarJuegoCategoria>();

		foreach (var categoria in JuegoTipos.CargarListado())
		{
			if (categoria != JuegoTipo.Bundle)
			{
				MostrarJuegoCategoria nuevaTienda = new MostrarJuegoCategoria();
				nuevaTienda.Estado = true;
				nuevaTienda.Checkbox = "checked";
				nuevaTienda.Categoria = categoria;

				nuevaLista.Add(nuevaTienda);
			}
		}

		return nuevaLista;
	}

	#endregion

	#region Noticias

	[PersistentState] public List<Noticias.Noticia> noticias { get; set; }
	private int noticiasDias = 3;

	private PeriodicTimer cronometroNoticias = null;
	private int cronometroNoticiasContador = 0;

	private async void CronometroNoticias(int limite)
	{  
		cronometroNoticias = new PeriodicTimer(TimeSpan.FromSeconds(1));

		while (await cronometroNoticias.WaitForNextTickAsync())
		{
			cronometroNoticiasContador += 1;

			if (cronometroNoticiasContador >= limite)
			{
				noticias = await BaseDatos.Noticias.Buscar.Actuales(tipoSeleccionadoNoticias, noticiasDias);

				cronometroNoticiasContador = 0;
			}

			await InvokeAsync(StateHasChanged);
		}
	}

	private NoticiaTipo tipoSeleccionadoNoticias = NoticiaTipo.Desconocido;

	[PersistentState]
	public List<NoticiaTipo> tiposActualesNoticias { get; set; }

	private async Task CambiarTipo(MouseEventArgs e, NoticiaTipo nuevoTipo)
	{
		tipoSeleccionadoNoticias = nuevoTipo;
		noticias = await BaseDatos.Noticias.Buscar.Actuales(tipoSeleccionadoNoticias, noticiasDias);
	}

	private string CambiarEstilo(NoticiaTipo nuevoTipo)
	{
		if (nuevoTipo != tipoSeleccionadoNoticias)
		{
			return "background-color: transparent;";
		}
		else
		{
			return "background-color: var(--botonSeleccionado);";
		}
	}

	#endregion

	#region Desplegable Minimos

	private string dropdownAbierto = string.Empty;
	private string dropdownHoverActivo = string.Empty; 

	private void DesplegarDropdown(string seccion, int juegoId, JuegoDRM drm)
	{
		if (juegoId > 0)
		{
			string key = seccion + juegoId.ToString() + "-" + ((int)drm).ToString();
			dropdownAbierto = dropdownAbierto == key ? string.Empty : key;
		}
	}

	private void AbrirDropdownHover(string seccion, int juegoId, JuegoDRM drm)
	{
		if (juegoId > 0)
		{
			string key = seccion + juegoId.ToString() + "-" + ((int)drm).ToString();
			dropdownAbierto = key;
			dropdownHoverActivo = key;
		}
	}

	private void CerrarDropdownHover(string seccion, int juegoId, JuegoDRM drm)
	{
		if (juegoId > 0)
		{
			string key = seccion + juegoId.ToString() + "-" + ((int)drm).ToString();

			Task.Delay(100).ContinueWith(_ =>
			{
				if (dropdownHoverActivo == key)
				{
					dropdownAbierto = string.Empty;
					dropdownHoverActivo = string.Empty;
					InvokeAsync(StateHasChanged);
				}
			});
		}
	}

	private void MantenerDropdownAbierto(string seccion, int juegoId, JuegoDRM drm)
	{
		if (juegoId > 0)
		{
			string key = seccion + juegoId.ToString() + "-" + ((int)drm).ToString();
			dropdownHoverActivo = key;
		}
	}

	private void CerrarAlSalirDelMenu(string seccion, int juegoId, JuegoDRM drm)
	{
		if (juegoId > 0)
		{
			dropdownAbierto = string.Empty;
			dropdownHoverActivo = string.Empty;
		}
	}

	private async Task CambiarEstadoDeseado(MouseEventArgs e, string usuarioId, JuegoMostrar juego, JuegoDRM drm)
	{
		bool estado = true;

		if (juego.Color == "var(--fondoAlerta)")
		{
			estado = false;
		}

		await Herramientas.Deseados.CambiarEstado(usuarioId, juego.Juego, estado, drm, false);

		foreach (var juego2 in juegosDestacadosMostrar)
		{
			if (juego2.Juego.Id == juego.Juego.Id && juego2.Juego.PrecioMinimosHistoricos[0].DRM == drm)
			{
				if (estado == true)
				{
					juego2.Color = "var(--fondoAlerta)";
				}
				else
				{
					juego2.Color = "var(--fondoBotonPequeño)";
				}
			}
		}

		foreach (var juego2 in juegosMinimosMostrar)
		{
			if (juego2.Juego.Id == juego.Juego.Id && juego2.Juego.PrecioMinimosHistoricos[0].DRM == drm)
			{
				if (estado == true)
				{
					juego2.Color = "var(--fondoAlerta)";
				}
				else
				{
					juego2.Color = "var(--fondoBotonPequeño)";
				}
			}
		}

		await InvokeAsync(StateHasChanged);
	}

	private void MostrarBotonDeseados(MouseEventArgs e, JuegoMostrar juego)
	{
		juego.DesplegableMostrar = true;
	}

	private void OcultarBotonDeseados(MouseEventArgs e, JuegoMostrar juego)
	{
		juego.DesplegableMostrar = false;
	}

	private async Task ExcluirJuego(MouseEventArgs e, string seccion, string usuarioId, JuegoMostrar juego)
	{
		if (seccion == "destacado")
		{
			cronometroContador = 0;

			if (posicionMostrarDestacados > 4)
			{
				posicionMostrarDestacados -= 1;
			}

			int juegoBorrar = juegosDestacadosMostrar.FindIndex(j => j.Juego.Id == juego.Juego.Id);

			if (juegoBorrar >= 0)
			{
				juegosDestacadosMostrar.RemoveAt(juegoBorrar);
			}

			videoDestacado = null;

			excluirJuegosIds.Add(juego.Juego.Id);

			foreach (var juego2 in juegosDestacadosMostrar)
			{
				excluirJuegosIds.Add(juego2.Juego.Id);
			}

			List<Juegos.Juego> nuevoJuego = await CargarJuegosDestacados(1);

			if (nuevoJuego?.Count == 1)
			{
				JuegoMostrar nuevoJuego2 = new JuegoMostrar
				{
					Juego = nuevoJuego[0],
					DeseadoImportado = false,
					Color = "var(--fondoBotonPequeño)",
					DesplegableMostrar = true
				};

				JuegoDRM drmDestacados = JuegoDRM.NoEspecificado;

				if (usuarioRegion == TiendaRegion.Europa)
				{
					drmDestacados = nuevoJuego2.Juego.PrecioMinimosHistoricos[0].DRM;
				}
				else if (usuarioRegion == TiendaRegion.EstadosUnidos)
				{
					drmDestacados = nuevoJuego2.Juego.PrecioMinimosHistoricosUS[0].DRM;
				}

				if (Herramientas.UsuarioJuegos.ComprobarSiTiene(juegosUsuarioIndex, nuevoJuego2.Juego, drmDestacados) == true)
				{
					nuevoJuego2.Color = "var(--fondoBien)";
				}
				else
				{
					if (Herramientas.Deseados.ComprobarSiEstaImportado(deseadosImportadosIndex, nuevoJuego2.Juego, drmDestacados, true) == true)
					{
						nuevoJuego2.Color = "var(--fondoAlerta)";
						nuevoJuego2.DeseadoImportado = true;
					}

					if (Herramientas.Deseados.ComprobarSiEstaWeb(deseadosWebIndex, nuevoJuego2.Juego, drmDestacados, true) == true)
					{
						nuevoJuego2.Color = "var(--fondoAlerta)";
					}
				}

				juegosDestacadosMostrar.AddRange(new List<JuegoMostrar> { nuevoJuego2 });
			}
		}
		else if (seccion == "minimos")
		{
			juegosMinimosMostrar.RemoveAll(j => j.Juego.Id == juego.Juego.Id);
		}

		await Herramientas.ExcluirJuegos.Añadir(usuarioId, juego.Juego.Id);

		juego.Excluido = true;
	}

	#endregion

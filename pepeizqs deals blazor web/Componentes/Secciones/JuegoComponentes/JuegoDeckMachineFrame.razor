@code {

    #nullable disable

    [Parameter]
    public Juegos.Juego juego { get; set; }

    [Parameter] 
    public string idioma { get; set; }

    [Parameter] 
    public bool enseñarSteamDeck { get; set; }

    [Parameter] 
    public bool enseñarSteamMachine { get; set; }

    [Parameter] 
    public bool enseñarSteamFrame { get; set; }

    [Parameter] 
    public bool enseñarSteamOS { get; set; }

    [Parameter] 
    public EventCallback OnCerrar { get; set; } 

    private bool usuarioEncimaCerrar = false;

    protected override async Task OnInitializedAsync()
    {
        bool actualizarDeckAPI = false;

        if (juego.DeckComprobacion == null)
        {
            actualizarDeckAPI = true;
        }
        else
        {
            if (juego.DeckComprobacion + TimeSpan.FromDays(180) > DateTime.Now)
            {
                actualizarDeckAPI = true;
            }

            if (juego.Deck > 0 && juego.DeckTokens == null)
            {
                actualizarDeckAPI = true;
            }

            if (juego.SteamMachine > 0 && juego.SteamMachineTokens == null)
            {
                actualizarDeckAPI = true;
            }

            if (juego.SteamFrame > 0 && juego.SteamFrameTokens == null)
            {
                actualizarDeckAPI = true;
            }

            if (juego.SteamOS > 0 && juego.SteamOSTokens == null)
            {
                actualizarDeckAPI = true;
            }
        }

        if (actualizarDeckAPI == true)
        {
            APIs.Steam.SteamDeckAPI deckAPI = await APIs.Steam.Juego.CargarDatosDeck(juego.Id, juego.IdSteam);
            bool vacio = true;

            if (deckAPI?.Datos?.Resultado != null)
            {
                juego.Deck = (JuegoDeck)int.Parse(deckAPI.Datos.Resultado.ToString());
                juego.DeckComprobacion = DateTime.Now;

                if (deckAPI.Datos.Tokens?.Count > 0)
                {
                    List<JuegoDeckToken> tokens = new List<JuegoDeckToken>();

                    foreach (var token in deckAPI.Datos.Tokens)
                    {
                        if (string.IsNullOrEmpty(token.Token) == false)
                        {
                            JuegoDeckToken nuevoToken = new JuegoDeckToken();
                            nuevoToken.Tipo = int.Parse(token.Tipo.ToString());
                            nuevoToken.Mensaje = token.Token;

                            tokens.Add(nuevoToken);
                        }
                    }

                    juego.DeckTokens = tokens;
                }

                juego.SteamOS = (JuegoSteamOS)int.Parse(deckAPI.Datos.SteamOSResultado.ToString());

                if (deckAPI.Datos.SteamOSTokens?.Count > 0)
                {
                    List<JuegoDeckToken> tokens = new List<JuegoDeckToken>();

                    foreach (var token in deckAPI.Datos.SteamOSTokens)
                    {
                        if (string.IsNullOrEmpty(token.Token) == false)
                        {
                            JuegoDeckToken nuevoToken = new JuegoDeckToken();
                            nuevoToken.Tipo = int.Parse(token.Tipo.ToString());
                            nuevoToken.Mensaje = token.Token;

                            tokens.Add(nuevoToken);
                        }
                    }

                    juego.SteamOSTokens = tokens;
                }

                if (deckAPI.Datos.SteamFrameResultado != null)
                {
                    juego.SteamFrame = (JuegoSteamFrame)int.Parse(deckAPI.Datos.SteamFrameResultado?.ToString());

                    if (deckAPI.Datos.SteamFrameTokens?.Count > 0)
                    {
                        List<JuegoDeckToken> tokens = new List<JuegoDeckToken>();

                        foreach (var token in deckAPI.Datos.SteamFrameTokens)
                        {
                            if (string.IsNullOrEmpty(token.Token) == false)
                            {
                                JuegoDeckToken nuevoToken = new JuegoDeckToken();
                                nuevoToken.Tipo = int.Parse(token.Tipo.ToString());
                                nuevoToken.Mensaje = token.Token;
                                tokens.Add(nuevoToken);
                            }
                        }

                        juego.SteamFrameTokens = tokens;
                    }
                }

                if (deckAPI.Datos.SteamMachineResultado != null)
                {
                    juego.SteamMachine = (JuegoSteamMachine)int.Parse(deckAPI.Datos.SteamMachineResultado?.ToString());

                    if (deckAPI.Datos.SteamMachineTokens?.Count > 0)
                    {
                        List<JuegoDeckToken> tokens = new List<JuegoDeckToken>();

                        foreach (var token in deckAPI.Datos.SteamMachineTokens)
                        {
                            if (string.IsNullOrEmpty(token.Token) == false)
                            {
                                JuegoDeckToken nuevoToken = new JuegoDeckToken();
                                nuevoToken.Tipo = int.Parse(token.Tipo.ToString());
                                nuevoToken.Mensaje = token.Token;
                                tokens.Add(nuevoToken);
                            }
                        }

                        juego.SteamMachineTokens = tokens;
                    }
                }

                vacio = false;
                await global::BaseDatos.Juegos.Actualizar.Deck(juego);
            }

            if (vacio == true)
            {
                juego.DeckComprobacion = DateTime.Now;
                await global::BaseDatos.Juegos.Actualizar.DeckVacio(juego);
            }
        }

        if (enseñarSteamDeck == true)
        {
            await MostrarSteamDeck();
        }
        else
        {
            if (enseñarSteamMachine == true)
            {
                await MostrarSteamMachine();
            }
            else
            {
                if (enseñarSteamFrame == true)
                {
                    await MostrarSteamFrame();
                }
                else
                {
                    if (enseñarSteamOS == true)
                    {
                        await MostrarSteamOS();
                    }
                }
            }
        }
    }

    #region Pestañas

    private enum PestañaElegida
    {
        SinElegir,
        SteamDeck,
        SteamMachine,
        SteamFrame,
        SteamOS
    }

    private PestañaElegida pestañaElegida = PestañaElegida.SinElegir;

    private void TransparentarFondos()
    {
        fondoSteamDeck = "background: transparent;";
        fondoSteamMachine = "background: transparent;";
        fondoSteamFrame = "background: transparent;";
        fondoSteamOS = "background: transparent;";
    }

    private string fondoSteamDeck = "background: transparent;";

    private async Task MostrarSteamDeck()
    {
        TransparentarFondos();

        fondoSteamDeck = "background: var(--botonSeleccionado);";
        pestañaElegida = PestañaElegida.SteamDeck;
    }

    private string fondoSteamMachine = "background: transparent;";

    private async Task MostrarSteamMachine()
    {
        TransparentarFondos();

        fondoSteamMachine = "background: var(--botonSeleccionado);";
        pestañaElegida = PestañaElegida.SteamMachine;
    }

    private string fondoSteamFrame = "background: transparent;";

    private async Task MostrarSteamFrame()
    {
        TransparentarFondos();

        fondoSteamFrame = "background: var(--botonSeleccionado);";
        pestañaElegida = PestañaElegida.SteamFrame;
    }

    private string fondoSteamOS = "background: transparent;";

    private async Task MostrarSteamOS()
    {
        TransparentarFondos();

        fondoSteamOS = "background: var(--botonSeleccionado);";
        pestañaElegida = PestañaElegida.SteamOS;
    }

    #endregion
}

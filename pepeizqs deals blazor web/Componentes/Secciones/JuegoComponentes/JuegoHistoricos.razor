@using Juegos
@using Tiendas2

@if (juego != null)
{
    string nombreGrafico = juego.Nombre + " (" + JuegoDRM2.DevolverDRM(drmGrafico) + ")";

    <div class="opciones-panel" style="padding: 0px;">
        <div class="caja-juego-contenido" style="display: flex; flex-direction: column; gap: 10px; width: 100%; height: 100%; overflow-y: scroll; scrollbar-color: var(--fondoCodigo) var(--fondoBotonPequeño);">
            <div style="display: flex; align-items: center; gap: 20px; background-color: rgba(255, 255, 255, 0.1); padding: 10px;">
                <button @onclick="OnCerrar" @onmouseenter="_ => usuarioEncimaCerrar = true" @onmouseleave="_ => usuarioEncimaCerrar = false" style="@(usuarioEncimaCerrar == true ? "background: var(--fondoBotonPequeñoHover);" : "background: var(--fondoBotonPequeño);") padding: 8px 10px; border: 0px;">
                    <div style="width: 24px; height: 24px;">
                        <svg class="svg-icono" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" style="fill: var(--colorTexto); transform: rotate(@(usuarioEncimaCerrar == true ? "180deg" : "0deg")); transition: transform 0.2s;">
                            <path d="M183.1 137.4C170.6 124.9 150.3 124.9 137.8 137.4C125.3 149.9 125.3 170.2 137.8 182.7L275.2 320L137.9 457.4C125.4 469.9 125.4 490.2 137.9 502.7C150.4 515.2 170.7 515.2 183.2 502.7L320.5 365.3L457.9 502.6C470.4 515.1 490.7 515.1 503.2 502.6C515.7 490.1 515.7 469.8 503.2 457.3L365.8 320L503.1 182.6C515.6 170.1 515.6 149.8 503.1 137.3C490.6 124.8 470.3 124.8 457.8 137.3L320.5 274.7L183.1 137.4z" />
                        </svg>
                    </div>
                </button>

                <div style="display: flex; align-items: center; gap: 20px;">
                    <img src="@juego.Imagenes?.Capsule_231x87" style="height: 44px;" />

                    <img src="@JuegoDRM2.SacarImagen(drmGrafico)" style="width: 24px; height: 24px;" />
                </div>

                @{
                    List<int> años = new List<int>();

                    if (usuarioRegion == TiendaRegion.Europa)
                    {
                        años = juego.Historicos.Select(h => h.Fecha.Year).Distinct().Reverse().ToList();
                    }
                    else if (usuarioRegion == TiendaRegion.EstadosUnidos)
                    {
                        años = juego.HistoricosUS.Select(h => h.Fecha.Year).Distinct().Reverse().ToList();
                    }

                    if (años?.Count > 0)
                    {
                        <div style="display: flex; align-items: center; gap: 10px;">
                            @foreach (var año in años)
                            {
                                bool seleccionado = añosMostrados.Contains(año);

                                <button @onclick="@(() => AlternarAño(año))" class="boton-historicos @(seleccionado ? "seleccionado" : "")" style="display: flex; align-items: center; gap: 8px;">
                                    @if (seleccionado == true)
                                    {
                                        <div style="width: 22px; height: 22px;">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" style="fill: none; stroke: var(--colorTexto); stroke-width: 60; stroke-linecap: round; stroke-linejoin: round;">
                                                <path d="M128 340 L280 480 L512 160" />
                                            </svg>
                                        </div>
                                    }
                                    <div>@año</div>
                                </button>
                            }
                        </div>
                    }
                }
            </div>

            <div style="padding: 10px; width: 100%; height: 100%;">
                @if (añosMostrados?.Count > 0)
                {
                    <JuegoHistoricosGrafico @key="@($"{drmGrafico}_{string.Join(",", añosMostrados)}")" dominio="@dominio" historicos="@historicosGrafico" drmGrafico="@drmGrafico" idioma="@idioma" usuarioRegion="@usuarioRegion" mostrarLabelsDuplicadas="@mostrarLabelsDuplicadas" />
                }
            </div>
        </div>
    </div>
}

@code {

    #nullable disable

    [Parameter]
    public Juegos.Juego juego { get; set; }

    [Parameter]
    public JuegoDRM drmGrafico { get; set; } = JuegoDRM.NoEspecificado;

    [Parameter]
    public TiendaRegion usuarioRegion { get; set; }

    [Parameter]
    public string idioma { get; set; }

    [Parameter]
    public string dominio { get; set; }

    [Parameter]
    public EventCallback OnCerrar { get; set; }

    [Parameter]
    public bool mostrarLabelsDuplicadas { get; set; }

    private bool usuarioEncimaCerrar = false;
    private List<JuegoHistorico> historicosGrafico = new List<JuegoHistorico>();
    private int añoGrafico = DateTime.Now.Year;
    private List<int> añosMostrados = new List<int>();

    protected override async Task OnInitializedAsync()
    {
        if (drmGrafico != JuegoDRM.NoEspecificado)
        {
            añosMostrados.Add(añoGrafico);

            if (usuarioRegion == TiendaRegion.Europa)
            {
                añoGrafico = juego.Historicos.Select(h => h.Fecha.Year).Distinct().Reverse().ToList().First();
                historicosGrafico = juego.Historicos.Where(x => x.DRM == drmGrafico && añosMostrados.Contains(x.Fecha.Year) == true).ToList();
            }
            else if (usuarioRegion == TiendaRegion.EstadosUnidos)
            {
                añoGrafico = juego.HistoricosUS.Select(h => h.Fecha.Year).Distinct().Reverse().ToList().First();
                historicosGrafico = juego.HistoricosUS.Where(x => x.DRM == drmGrafico && añosMostrados.Contains(x.Fecha.Year) == true).ToList();
            }
        }
    }

    private async Task AlternarAño(int año)
    {
        if (añosMostrados.Contains(año) == true)
        {
            if (añosMostrados.Count > 1)
            {
                await OcultarAño(año);
            }
        }
        else
        {
            await CambiarAño(año);
        }
    }

    private async Task CambiarAño(int año)
    {
        await InvokeAsync(StateHasChanged);

        bool añadirMostrados = true;

        foreach (var añoMostrado in añosMostrados)
        {
            if (añoMostrado == año)
            {
                añadirMostrados = false;
                break;
            }
        }

        if (añadirMostrados == true)
        {
            añosMostrados.Add(año);
        }

        añoGrafico = año;

        if (drmGrafico != JuegoDRM.NoEspecificado)
        {
            if (usuarioRegion == TiendaRegion.Europa)
            {
                historicosGrafico = juego.Historicos.Where(x => x.DRM == drmGrafico && añosMostrados.Contains(x.Fecha.Year) == true).ToList();
            }
            else if (usuarioRegion == TiendaRegion.EstadosUnidos)
            {
                historicosGrafico = juego.HistoricosUS.Where(x => x.DRM == drmGrafico && añosMostrados.Contains(x.Fecha.Year) == true).ToList();
            }
        }
    }

    private async Task OcultarAño(int año)
    {
        await InvokeAsync(StateHasChanged);

        añosMostrados.Remove(año);

        if (drmGrafico != JuegoDRM.NoEspecificado)
        {
            if (usuarioRegion == TiendaRegion.Europa)
            {
                historicosGrafico = juego.Historicos.Where(x => x.DRM == drmGrafico && añosMostrados.Contains(x.Fecha.Year) == true).ToList();
            }
            else if (usuarioRegion == TiendaRegion.EstadosUnidos)
            {
                historicosGrafico = juego.HistoricosUS.Where(x => x.DRM == drmGrafico && añosMostrados.Contains(x.Fecha.Year) == true).ToList();
            }
        }
    }
}

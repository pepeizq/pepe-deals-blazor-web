	private void ActualizarPreciosHistoricos(Juegos.Juego juego, TiendaRegion region)
	{
		if (juego != null)
		{
			var precios = region == TiendaRegion.Europa ? juego.PrecioMinimosHistoricos : juego.PrecioMinimosHistoricosUS;

			if (precios?.Count > 0)
			{
				foreach (var precio in precios)
				{
					if (precio.DRM != Juegos.JuegoDRM.NoEspecificado && precio.DRM != Juegos.JuegoDRM.Microsoft)
					{
						if (!preciosHistoricos.Contains(precio.DRM))
						{
							preciosHistoricos.Add(precio.DRM);
						}
					}
				}
			}
		}
	}


		await Herramientas.Deseados.CambiarEstado(usuarioId, juego.Juego, juego.DeseadoWeb, drm, true);

		var juegoEnLista = juegosMostrar.FirstOrDefault(j => j.Juego.Id == juego.Juego.Id);


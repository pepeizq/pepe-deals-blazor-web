				if (string.IsNullOrEmpty(usuarioId) == false)
				{
					JuegoDRM drmUsar = JuegoDRM.NoEspecificado;

					if (usuarioRegion == TiendaRegion.Europa)
					{
						drmUsar = juego.PrecioMinimosHistoricos[0].DRM;
					}
					else if (usuarioRegion == TiendaRegion.EstadosUnidos)
					{
						drmUsar = juego.PrecioMinimosHistoricosUS[0].DRM;

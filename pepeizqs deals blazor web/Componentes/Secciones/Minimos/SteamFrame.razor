	protected override async Task OnInitializedAsync()
	{
		Herramientas.ContextoUsuarioDatos datos = Herramientas.ContextoUsuario.Leer(Contexto);
		idioma = datos.Idioma;
		usuarioId = datos.UsuarioId;
		userAgent = datos.UserAgent;
		dominio = datos.Dominio;
		usuarioRegion = datos.Region;

		if (string.IsNullOrEmpty(usuarioId) == false)
		{
			Task<string> tareaIdioma = BaseDatos.Usuarios.Buscar.IdiomaSobreescribir(usuarioId);
			Task<Herramientas.UsuarioListadosJuegos> tareaJuegos = (juegosUsuario != null) ? Task.FromResult(juegosUsuario) : Herramientas.UsuarioJuegos.Cargar(usuarioId);
			Task<Usuario> tareaDeseados = (deseadosUsuario != null) ? Task.FromResult(deseadosUsuario) : BaseDatos.Usuarios.Buscar.DeseadosTiene(usuarioId);
			Task<DateTime?> tareaPatreon = BaseDatos.Usuarios.Buscar.FechaPatreon(usuarioId);
			Task<bool> tareaAdmin = BaseDatos.Usuarios.Buscar.RolDios(usuarioId);
			Task<int> tareaRegion = BaseDatos.Usuarios.Buscar.OpcionInt(usuarioId, "Currency");
			Task<Usuario> tareaUsuario = (opciones != null) ? Task.FromResult(opciones) : BaseDatos.Usuarios.Buscar.OpcionesSteamFrame(usuarioId);

			await Task.WhenAll(tareaIdioma, tareaJuegos, tareaDeseados, tareaPatreon, tareaAdmin, tareaRegion, tareaUsuario);

			idioma = tareaIdioma.Result;
			juegosUsuario = tareaJuegos.Result;
			deseadosUsuario = tareaDeseados.Result;
			usuarioPatreon = Herramientas.Patreon.VerificarActivo(tareaPatreon.Result);
			usuarioAdmin = tareaAdmin.Result;
			usuarioRegion = (TiendaRegion)tareaRegion.Result;
			opciones = tareaUsuario.Result;

			if (juegosUsuarioIndex == null)
			{
				juegosUsuarioIndex = Herramientas.UsuarioJuegos.CrearIndex(juegosUsuario);
			}

			excluirJuegosIds = juegosUsuarioIndex.Excluidos.ToList();

			if (deseadosImportadosIndex == null)
			{
				deseadosImportadosIndex = Herramientas.Deseados.CrearImportadosIndex(deseadosUsuario);
			}

			if (deseadosWebIndex == null)
			{
				deseadosWebIndex = Herramientas.Deseados.CrearWebIndex(deseadosUsuario);
			}

			if (opciones != null)
			{
				if (opciones.Currency.HasValue == true)
				{
					usuarioRegion = (TiendaRegion)opciones.Currency.Value;
				}

				if (opciones.SteamFrameOption1 == true)
				{
					ocultarJuegosUsuario = "checked";
				}
				else
				{
					ocultarJuegosUsuario = null;
				}

				if (opciones.SteamFrameOption2.HasValue == true)
				{
					precioMaximo = opciones.SteamFrameOption2.Value;
				}

				if (opciones.SteamFrameOption3.HasValue == true)
				{
					descuentoMinimo = opciones.SteamFrameOption3.Value;
				}

				if (opciones.SteamFrameOption4.HasValue == true)
				{
					minimoReseñas = opciones.SteamFrameOption4.Value;
				}

				ServicioOpciones.OnMostrarOpcionesChanged += StateHasChanged;
			}
		}

		if (seccionActual == SeccionFrame.Verificados)
		{
			await MostrarVerificados(true);
		}
		else if (seccionActual == SeccionFrame.Jugables)
		{
			await MostrarJugables(true);
		}

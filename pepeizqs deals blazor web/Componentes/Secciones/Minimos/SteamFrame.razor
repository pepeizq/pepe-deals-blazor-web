	private async Task CambiarReseñasMinimo()
	{
		if (seccionActual == SeccionFrame.Verificados)
		{
			await MostrarVerificados(true);
		}
		else if (seccionActual == SeccionFrame.Jugables)
		{
			await MostrarJugables(true);
		}

		if (string.IsNullOrEmpty(usuarioId) == false)
		{
			await BaseDatos.Usuarios.Actualizar.Opcion("SteamFrameOption4", minimoReseñas, usuarioId);
		}
	}

	#endregion

	private async Task ActivarTooltip(string triggerId, string tooltipId)
	{
		if (moduloJs != null)
		{
			await moduloJs.InvokeVoidAsync("activarTooltip", triggerId, tooltipId);
		}
	}

	private async Task DesactivarTooltip(string triggerId)
	{
		if (moduloJs != null)
		{
			await moduloJs.InvokeVoidAsync("desactivarTooltip", triggerId);
		}
	}
}

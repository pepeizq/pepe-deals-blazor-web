@page "/steamframe"

@implements IAsyncDisposable

@using Juegos
@using Tiendas2
@using pepeizqs_deals_blazor_web.Componentes.Interfaz
@using pepeizqs_deals_web.Data
@using static pepeizqs_deals_blazor_web.Componentes.Secciones.Minimos.Minimos

@inject IHttpContextAccessor Contexto
@inject IJSRuntime JavaScript
@inject Servicios.Opciones ServicioOpciones

<Titulo tipo="@Titulo.Tipo.SteamFrame" idioma="@idioma" dominio="@dominio" />

<div>
	@* <img class="juego-fondo" src="/imagenes/otros/steamframe_fondo.webp" alt="Steam Frame" fetchpriority="high" />  *@

	<div>
		<div class="caja-steamframe" style="margin: 40px auto; display: flex; justify-content: center; max-width: 350px; border-radius: 20px; padding: 20px 40px;">
			<img src="/imagenes/otros/steamframe_logo.webp" alt="Steam Frame" style="width: 100%; height: 100%;" />
		</div>

		<div style="display: flex; align-items: center; justify-content: center; margin-bottom: 10px; transition: transform 0.3s ease, opacity 0.3s ease; width: fit-content; margin-left: auto; margin-right: auto;">
			<div class="caja-steamframe">
				<button @onclick="MostrarVerificados" class="boton-steamframe" style="@fondoVerificados border: 0px; height: 50px; padding: 15px 25px; display: flex; align-items: center; color: var(--colorTexto); border-radius: inherit; @(mostrarBuscador ? "" : "gap: 20px;")">
					<div style="display: flex; width: 30px; height: 30px;">
						<svg viewBox="0 0 20 20" fill="var(--deckVerificado)" xmlns="http://www.w3.org/2000/svg">
							<path fill-rule="evenodd" clip-rule="evenodd" d="M10 19C14.9706 19 19 14.9706 19 10C19 5.02944 14.9706 1 10 1C5.02944 1 1 5.02944 1 10C1 14.9706 5.02944 19 10 19ZM8.33342 11.9222L14.4945 5.76667L16.4556 7.72779L8.33342 15.8556L3.26675 10.7833L5.22786 8.82223L8.33342 11.9222Z"></path>
						</svg>
					</div>

					<div class="caja-steamframe-animacion @(mostrarBuscador ? "" : "visible")">
						@Herramientas.Idiomas.BuscarTexto(idioma, "String1", "SteamFrame")
					</div>
				</button>

				<button @onclick="MostrarJugables" class="boton-steamframe" style="@fondoJugables border: 0px; height: 50px; padding: 15px 25px; display: flex; align-items: center; color: var(--colorTexto); border-radius: inherit; @(mostrarBuscador ? "" : "gap: 20px;")">
					<div style="display: flex; width: 30px; height: 30px;">
						<svg viewBox="0 0 20 20" fill="var(--deckJugable)" xmlns="http://www.w3.org/2000/svg">
							<path fill-rule="evenodd" clip-rule="evenodd" d="M10 19C14.9706 19 19 14.9706 19 10C19 5.02944 14.9706 1 10 1C5.02944 1 1 5.02944 1 10C1 14.9706 5.02944 19 10 19ZM8.61079 9.44444V15H11.3886V9.44444H8.61079ZM9.07372 8.05245C9.34781 8.23558 9.67004 8.33333 9.99967 8.33333C10.4417 8.33333 10.8656 8.15774 11.1782 7.84518C11.4907 7.53262 11.6663 7.10869 11.6663 6.66667C11.6663 6.33703 11.5686 6.0148 11.3855 5.74072C11.2023 5.46663 10.942 5.25301 10.6375 5.12687C10.3329 5.00072 9.99783 4.96771 9.67452 5.03202C9.35122 5.09633 9.05425 5.25507 8.82116 5.48815C8.58808 5.72124 8.42934 6.01821 8.36503 6.34152C8.30072 6.66482 8.33373 6.99993 8.45988 7.30447C8.58602 7.60902 8.79964 7.86931 9.07372 8.05245Z"></path>
						</svg>
					</div>

					<div class="caja-steamframe-animacion @(mostrarBuscador ? "" : "visible")">
						@Herramientas.Idiomas.BuscarTexto(idioma, "String2", "SteamFrame")
					</div>
				</button>
			</div>

			<div style="display: flex; align-items: center; gap: 25px; max-width: 500px; height: 45px; margin-left: 40px; @anchoBuscador">
				<div class="tooltip-juego" id="trigger-steamframe-search"
					 @onmouseenter="@(() => ActivarTooltip("trigger-steamframe-search", "tooltip-steamframe-search"))"
					 @onmouseleave="@(() => DesactivarTooltip("trigger-steamframe-search"))">
					<button @onclick="MostrarOcultarBuscador" style="background: transparent; border: 0px;">
						<div style="width: 24px; height: 24px;">
							<svg class="svg-boton" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
								<path d="M480 272C480 317.9 465.1 360.3 440 394.7L566.6 521.4C579.1 533.9 579.1 554.2 566.6 566.7C554.1 579.2 533.8 579.2 521.3 566.7L394.7 440C360.3 465.1 317.9 480 272 480C157.1 480 64 386.9 64 272C64 157.1 157.1 64 272 64C386.9 64 480 157.1 480 272zM272 416C351.5 416 416 351.5 416 272C416 192.5 351.5 128 272 128C192.5 128 128 192.5 128 272C128 351.5 192.5 416 272 416z" />
							</svg>
						</div>
					</button>

					<div id="tooltip-steamframe-search" class="tooltip-relleno">
						<div style="margin: 8px; max-width: 300px; font-size: 14px;">
							@Herramientas.Idiomas.BuscarTexto(idioma, "String3", "SteamFrame")
						</div>
					</div>
				</div>

				<div class="caja-steamframe caja-steamframe-animacion @(mostrarBuscador ? "visible" : "")">
					<input type="text" @bind-value="textoBuscador" @bind-value:event="oninput" @bind-value:after="TextoCambiaBuscador" @onclick="ClickBuscador" @onfocusout="PerderBuscador" class="entrada-texto" style="border-radius: inherit; color: var(--colorTexto); padding: 5px 15px; border: 0px; transition: background-color 1000ms linear; @fondoBuscador" placeholder="@Herramientas.Idiomas.BuscarTexto(idioma, "String3", "SteamFrame")" />
				</div>
			</div>
		</div>

		@if (mostrarNoResultados == true)
		{
			<div class="caja-steamframe" style="background-color: var(--noResultados); justify-content: center; margin: 40px auto; padding: 20px; border-radius: 30px; max-width: 600px;">
				<div style="width: 30px; height: 30px; flex-shrink: 0;">
					<svg class="svg-boton" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
						<path d="M528 320C528 205.1 434.9 112 320 112C205.1 112 112 205.1 112 320C112 434.9 205.1 528 320 528C434.9 528 528 434.9 528 320zM64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM320 240C302.3 240 288 254.3 288 272C288 285.3 277.3 296 264 296C250.7 296 240 285.3 240 272C240 227.8 275.8 192 320 192C364.2 192 400 227.8 400 272C400 319.2 364 339.2 344 346.5L344 350.3C344 363.6 333.3 374.3 320 374.3C306.7 374.3 296 363.6 296 350.3L296 342.2C296 321.7 310.8 307 326.1 302C332.5 299.9 339.3 296.5 344.3 291.7C348.6 287.5 352 281.7 352 272.1C352 254.4 337.7 240.1 320 240.1zM288 432C288 414.3 302.3 400 320 400C337.7 400 352 414.3 352 432C352 449.7 337.7 464 320 464C302.3 464 288 449.7 288 432z" />
					</svg>
				</div>

				<div>
					@Herramientas.Idiomas.BuscarTexto(idioma, "String9", "SteamFrame")
				</div>
			</div>
		}
		else
		{
			@if (juegosMostrar?.Count > 0)
			{
				<div style="max-width: 1000px; margin: 0px auto; display: flex; flex-direction: column; gap: 30px;">
					<Virtualize Context="juego" Items="juegosMostrar" ItemSize="107" OverscanCount="3">
						<ItemContent>
							@if (juego.Excluido == false)
							{
								JuegoDRM drmJuego = JuegoDRM.NoEspecificado;

								if (usuarioRegion == TiendaRegion.Europa)
								{
									drmJuego = juego.Juego.PrecioMinimosHistoricos[0].DRM;
								}
								else if (usuarioRegion == TiendaRegion.EstadosUnidos)
								{
									drmJuego = juego.Juego.PrecioMinimosHistoricosUS[0].DRM;
								}

								<div @key="juego.Juego.Id - drmJuego" style="display: flex; align-items: center; gap: 20px; position: relative;" @onmouseenter="(e => MostrarBotonDeseados(e, juego))" @onmouseleave="(e => OcultarBotonDeseados(e, juego))">
									<div style="width: 100%; overflow: hidden; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.28),0px 0px 1px 0px rgba(0, 0, 0, 0.24);">
										<CajaJuego region="@usuarioRegion" idioma="@idioma" juego="@juego.Juego" color="@juego.Color" juegosUsuarioIndex="@juegosUsuarioIndex" usuarioDeseadosImportados="@deseadosImportadosIndex" usuarioDeseadosWeb="@deseadosWebIndex" tipo="CajaJuego.Tipo.SteamFrame" userAgent="@userAgent" />
									</div>

									@if (string.IsNullOrEmpty(usuarioId) == false && juego.Tiene == false && juego.DesplegableMostrar == true)
									{
										<div style="position: absolute; top: 0; left: 0;">
											<button @onclick="@(e => DesplegarDropdown(juego.Juego.Id, drmJuego))"
													class="boton-pequeño" style="width: fit-content; padding: 10px; background-color: @juego.Color;">
												<div class="svg-boton" style="display: flex;">
													<svg style="width: 20px; height: 20px; transform: rotate(@(dropdownAbierto == juego.Juego.Id.ToString() + "-" + ((int)drmJuego).ToString() ? "180deg" : "0deg")); transition: transform 0.2s;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
														<path d="M297.4 438.6C309.9 451.1 330.2 451.1 342.7 438.6L502.7 278.6C515.2 266.1 515.2 245.8 502.7 233.3C490.2 220.8 469.9 220.8 457.4 233.3L320 370.7L182.6 233.4C170.1 220.9 149.8 220.9 137.3 233.4C124.8 245.9 124.8 266.2 137.3 278.7L297.3 438.7z" />
													</svg>
												</div>
											</button>
										</div>

										@if (dropdownAbierto == juego.Juego.Id.ToString() + "-" + ((int)drmJuego).ToString())
										{
											<div style="position: absolute; top: 35px; left: 0; background-color: var(--fondo); border: 1px solid var(--fondoCodigo); box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); z-index: 1000; width: fit-content; overflow: hidden; display: flex; flex-direction: column;">
												@if (juego.DeseadoImportado == false)
												{
													<button @onclick="@(async e => { await CambiarEstadoDeseado(e, usuarioId, juego, drmJuego); })"
															style="width: 100%; padding: 10px 12px; text-align: left; border: none; cursor: pointer; border-bottom: 1px solid var(--fondoCodigo); background-color: var(--fondoBotonPequeño); transition: background-color 0.2s;"
															onmouseover="this.style.backgroundColor='var(--fondoBotonPequeñoHover)'"
															onmouseout="this.style.backgroundColor='var(--fondoBotonPequeño)'">
														<div style="display: flex; align-items: center; gap: 10px;">
															<div style="width: 20px; height: 20px; display: flex; fill: var(--colorTexto);">
																@if (juego.DeseadoWeb == true)
																{
																	<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
																		<path d="M183.1 137.4C170.6 124.9 150.3 124.9 137.8 137.4C125.3 149.9 125.3 170.2 137.8 182.7L275.2 320L137.9 457.4C125.4 469.9 125.4 490.2 137.9 502.7C150.4 515.2 170.7 515.2 183.2 502.7L320.5 365.3L457.9 502.6C470.4 515.1 490.7 515.1 503.2 502.6C515.7 490.1 515.7 469.8 503.2 457.3L365.8 320L503.1 182.6C515.6 170.1 515.6 149.8 503.1 137.3C490.6 124.8 470.3 124.8 457.8 137.3L320.5 274.7L183.1 137.4z" />
																	</svg>
																}
																else
																{
																	<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
																		<path d="M341.5 45.1C337.4 37.1 329.1 32 320.1 32C311.1 32 302.8 37.1 298.7 45.1L225.1 189.3L65.2 214.7C56.3 216.1 48.9 222.4 46.1 231C43.3 239.6 45.6 249 51.9 255.4L166.3 369.9L141.1 529.8C139.7 538.7 143.4 547.7 150.7 553C158 558.3 167.6 559.1 175.7 555L320.1 481.6L464.4 555C472.4 559.1 482.1 558.3 489.4 553C496.7 547.7 500.4 538.8 499 529.8L473.7 369.9L588.1 255.4C594.5 249 596.7 239.6 593.9 231C591.1 222.4 583.8 216.1 574.8 214.7L415 189.3L341.5 45.1z" />
																	</svg>
																}
															</div>

															<span style="color: var(--colorTexto); font-size: 16px;">
																@if (juego.DeseadoWeb == true)
																{
																	@Herramientas.Idiomas.BuscarTexto(idioma, "String13", "Index")
																}
																else
																{
																	@Herramientas.Idiomas.BuscarTexto(idioma, "String12", "Index")
																}
															</span>
														</div>
													</button>
												}

												<button @onclick="@(async e => { await ExcluirJuego(e, usuarioId, juego); })"
														style="width: 100%; padding: 10px 12px; text-align: left; border: none; cursor: pointer; border-bottom: 1px solid var(--fondoCodigo); background-color: var(--fondoBotonPequeño); transition: background-color 0.2s;"
														onmouseover="this.style.backgroundColor='var(--fondoBotonPequeñoHover)'"
														onmouseout="this.style.backgroundColor='var(--fondoBotonPequeño)'">
													<div style="display: flex; align-items: center; gap: 10px;">
														<div style="width: 20px; height: 20px; display: flex; fill: var(--colorTexto);">
															<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
																<path d="M431.2 476.5L163.5 208.8C141.1 240.2 128 278.6 128 320C128 426 214 512 320 512C361.5 512 399.9 498.9 431.2 476.5zM476.5 431.2C498.9 399.8 512 361.4 512 320C512 214 426 128 320 128C278.5 128 240.1 141.1 208.8 163.5L476.5 431.2zM64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320z" />
															</svg>
														</div>

														<span style="color: var(--colorTexto); font-size: 16px;">
															@Herramientas.Idiomas.BuscarTexto(idioma, "String16", "Index")
														</span>
													</div>
												</button>
											</div>
										}
									}
								</div>
							}
						</ItemContent>
					</Virtualize>
				</div>

				if (string.IsNullOrEmpty(usuarioId) == false)
				{
					if (usuarioPatreon == true || usuarioAdmin == true)
					{
						if (posicionJuegos > 950 && posicionJuegos <= 1000)
						{
							llegadoLimite = true;
						}
					}
					else
					{
						if (posicionJuegos > 450 && posicionJuegos <= 500)
						{
							llegadoLimite = true;
						}
					}
				}
				else
				{
					if (posicionJuegos > 150 && posicionJuegos <= 200)
					{
						llegadoLimite = true;
					}
				}

				<div style="margin-bottom: 40px; display: flex; align-items: center; justify-content: center; gap: 40px;">
					@if (Herramientas.Bots.UserAgentEsBot(userAgent) == false && string.IsNullOrEmpty(textoBuscador) == true)
					{
						if (llegadoLimite == false)
						{
							if (cargandoMas == false)
							{
								<button class="boton-pequeño" @onclick="CargarMas" style="width: fit-content; padding: 15px 30px;">
									@if (seccionActual == SeccionFrame.Verificados)
									{
										@Herramientas.Idiomas.BuscarTexto(idioma, "String4", "SteamFrame")
									}
									else if (seccionActual == SeccionFrame.Jugables)
									{
										@Herramientas.Idiomas.BuscarTexto(idioma, "String5", "SteamFrame")
									}
								</button>
							}
							else
							{
								<div>
									@Herramientas.Idiomas.BuscarTexto(idioma, "String6", "SteamFrame")
								</div>
							}
						}
					}
				</div>
			}
		}
	</div>
</div>

@if (mostrarOpciones == true)
{
	<div class="opciones-panel">
		<div style="max-width: 800px; width: 100%; background-color: var(--fondoSubcabecera); border: 2px solid var(--fondoSubcabecera); margin: 20px auto; overflow-y: scroll; scrollbar-color: var(--fondoCodigo) var(--fondoOscuro); border-radius: 20px; box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.28),0px 0px 2px 0px rgba(0, 0, 0, 0.24);">
			<div style="display: flex; align-items: center; gap: 30px; padding: 20px 30px; background: color-mix(in srgb, var(--fondoSubcabecera) 55%, var(--fondoBotonPequeño)); position: sticky;">
				<button @onclick="MostrarOcultarOpciones" @onmouseenter="_ => usuarioEncimaOpciones = true" @onmouseleave="_ => usuarioEncimaOpciones = false" style="@(usuarioEncimaOpciones == true ? "background: var(--fondoBotonPequeñoHover);" : "background: var(--fondoBotonPequeño);") padding: 8px 10px; border: 0px; position: absolute;">
					<div style="width: 24px; height: 24px;">
						<svg class="svg-icono" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" style="fill: var(--colorTexto); transform: rotate(@(usuarioEncimaOpciones == true ? "180deg" : "0deg")); transition: transform 0.2s;">
							<path d="M183.1 137.4C170.6 124.9 150.3 124.9 137.8 137.4C125.3 149.9 125.3 170.2 137.8 182.7L275.2 320L137.9 457.4C125.4 469.9 125.4 490.2 137.9 502.7C150.4 515.2 170.7 515.2 183.2 502.7L320.5 365.3L457.9 502.6C470.4 515.1 490.7 515.1 503.2 502.6C515.7 490.1 515.7 469.8 503.2 457.3L365.8 320L503.1 182.6C515.6 170.1 515.6 149.8 503.1 137.3C490.6 124.8 470.3 124.8 457.8 137.3L320.5 274.7L183.1 137.4z" />
						</svg>
					</div>
				</button>

				<div style="display: flex; flex-direction: column; gap: 5px; width: 100%; align-items: center;">
					<div style="font-size: 20px;">
						@Herramientas.Idiomas.BuscarTexto(idioma, "String10", "SteamFrame")
					</div>
				</div>
			</div>

			<div style="display: flex; flex-direction: column; gap: 30px; padding: 30px;">
				<div style="border-radius: 10px;">
					<div style="display: flex; align-items: center; gap: 30px; padding: 15px 20px; background: color-mix(in srgb, var(--fondoSubcabecera) 55%, var(--fondoBotonPequeño)); border-top-left-radius: inherit; border-top-right-radius: inherit;">
						@Herramientas.Idiomas.BuscarTexto(idioma, "String15", "SteamFrame")
					</div>

					<div style="display: flex; flex-direction: column; gap: 5px; border-bottom-left-radius: inherit; border-bottom-right-radius: inherit;">
						<div style="background-color: var(--fondoSubsubcabecera); display: flex; align-items: center; gap: 20px; padding: 20px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.1),0px 0px 2px 0px rgba(0, 0, 0, 0.1); border-bottom-left-radius: inherit; border-bottom-right-radius: inherit;">
							<div class="checkbox-caja">
								<input type="checkbox" class="checkbox-interior" checked="@ocultarJuegosUsuario" @onchange="OcultarJuegosUsuario">
							</div>

							<div>
								@Herramientas.Idiomas.BuscarTexto(idioma, "String11", "SteamFrame")
							</div>
						</div>
					</div>
				</div>

				<div style="border-radius: 10px;">
					<div style="display: flex; align-items: center; gap: 30px; padding: 15px 20px; background: color-mix(in srgb, var(--fondoSubcabecera) 55%, var(--fondoBotonPequeño)); border-top-left-radius: inherit; border-top-right-radius: inherit;">
						@Herramientas.Idiomas.BuscarTexto(idioma, "String16", "SteamFrame")
					</div>

					<div style="display: flex; flex-direction: column; gap: 5px; border-bottom-left-radius: inherit; border-bottom-right-radius: inherit;">
						<div style="background-color: var(--fondoSubsubcabecera); display: flex; align-items: center; gap: 20px; padding: 20px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.1),0px 0px 2px 0px rgba(0, 0, 0, 0.1);">
							<div style="width: 100%;">
								@Herramientas.Idiomas.BuscarTexto(idioma, "String12", "SteamFrame")
							</div>

							<div>
								@if (usuarioRegion == TiendaRegion.Europa)
								{
									@(precioMaximo.ToString() + "€")
								}
								else if (usuarioRegion == TiendaRegion.EstadosUnidos)
								{
									@("$" + precioMaximo.ToString())
								}
							</div>

							<div style="background: rgba(0,0,0,0.2); border-radius: 10px; border: 1px solid var(--glaseadoBorde); padding: 10px 15px;">
								<input type="range" min="5" max="100" step="5" list="precios" @bind-value="precioMaximo" @bind-value:event="oninput" @bind-value:after="CambiarPrecioMaximo" />

								<datalist id="precios">
									<option value="5" label="5€"></option>
									<option value="20" label="20€"></option>
									<option value="40" label="40€"></option>
									<option value="60" label="60€"></option>
									<option value="80" label="80€"></option>
									<option value="100" label="100€"></option>
								</datalist>
							</div>
						</div>

						<div style="background-color: var(--fondoSubsubcabecera); display: flex; align-items: center; gap: 20px; padding: 20px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.1),0px 0px 2px 0px rgba(0, 0, 0, 0.1);">
							<div style="width: 100%;">
								@Herramientas.Idiomas.BuscarTexto(idioma, "String13", "SteamFrame")
							</div>

							<div>
								@descuentoMinimo%
							</div>

							<div style="background: rgba(0,0,0,0.2); border-radius: 10px; border: 1px solid var(--glaseadoBorde); padding: 10px 15px;">

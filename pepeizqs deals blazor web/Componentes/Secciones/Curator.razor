@page "/curator/{slug}/"

@using APIs.Steam
@using Juegos
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.AspNetCore.Identity
@using Microsoft.VisualBasic
@using Tiendas2
@using pepeizqs_deals_web.Data
@using pepeizqs_deals_blazor_web.Componentes.Interfaz

@inject IHttpContextAccessor Contexto
@inject IJSRuntime JavaScript

<style>
	.caja-curator-contenido {
		background-color: var(--fondoSubsubcabecera);
		box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.28),0px 0px 2px 0px rgba(0, 0, 0, 0.24);
		border-radius: 20px;
	}
</style>

<script>
	window.setupVideoAutoplay = function() {
		const videos = document.querySelectorAll('.video-autoplay');
    
		if (videos.length === 0) {
			return;
		}
    
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				const video = entry.target;
            
				if (entry.isIntersecting) {
					video.play();
				} else {
					video.pause();
				}
			});
		}, {
			threshold: 0.5
		});

		videos.forEach(video => observer.observe(video));
	}
</script>

@if (curator != null)
{
	string titulo = curator.Nombre + " (Curator)";
	string descripcion = Herramientas.Idiomas.BuscarTexto(idioma, "Subtitle", "Curators");
	string enlace = "https://" + dominio + "/curator/" + slug + "/";
	string imagen = "https://" + dominio + "/logo/logoentrada2.webp";

	if (string.IsNullOrEmpty(curator.Descripcion) == false)
	{
		descripcion = curator.Descripcion;
	}

	if (curator.Imagen != null)
	{
		if (string.IsNullOrEmpty(curator.Imagen) == false)
		{
			imagen = curator.Imagen;
		}
	}

	string keywords = "curator";

	if (curator.Nombre != null)
	{
		string[] keywordsEnBruto = Herramientas.Buscador.LimpiarNombre(curator.Nombre, false).Split(' ');
		List<string> keywordsLista = new List<string>();
		keywordsLista.AddRange(keywordsEnBruto);

		foreach (string keyword in keywordsLista)
		{
			if (keyword.Length > 3 && keywords.Contains(keyword) == false)
			{
				keywords = keywords + ", " + keyword;
			}
		}
	}

	string contenidoJson = @"{
        ""@context"": ""https://schema.org"",
		""@type"": ""ProfilePage"",
		""mainEntity"": {
			""@type"": ""Organization"",
			""name"": ""@nombreCurator"",
			""description"": ""@descripcion"",
			""image"": ""@imagen""
	";

	contenidoJson = contenidoJson.Replace("@nombreCurator", curator.Nombre);
	contenidoJson = contenidoJson.Replace("@descripcion", descripcion);
	contenidoJson = contenidoJson.Replace("@imagen", imagen);

	if (curator.Web != null)
	{
		if (string.IsNullOrEmpty(curator.Web.Enlace) == false)
		{
			contenidoJson = contenidoJson + @",
				""sameAs"": [ ""@enlace"" ]";

			contenidoJson = contenidoJson.Replace("@enlace", curator.Web.Enlace);
		}
	}

	contenidoJson = contenidoJson + "}" + Environment.NewLine + "}";

	<Titulo tipo="@Titulo.Tipo.Curator" idioma="@idioma" dominio="@dominio" tituloCurator="@titulo" descripcionCurator="@descripcion" enlaceCurator="@enlace"
			imagenCurator="@imagen" keywords="@keywords" contenidoJsonCurator="@contenidoJson"/>

	<div class="subcabecera" style="position: relative; overflow: hidden; backdrop-filter: blur(10px);">
		@if (string.IsNullOrEmpty(curator.ImagenFondo) == false)
		{
			<div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-image: url('@Herramientas.Ficheros.Imagenes.ServidorExterno(curator.ImagenFondo)'); background-size: cover; background-position: center; opacity: 0.3; z-index: 0;"></div>
		}
    
		<div class="cuerpo-ancho sub-subcabecera" style="flex-wrap: nowrap; position: relative; z-index: 2;">
			<div style="display: flex; align-items: center; background: linear-gradient(135deg, rgba(var(--fondoBotonPequeño), 0.8), rgba(var(--fondoCuerpo), 0.9)); backdrop-filter: blur(20px); z-index: 1;">
				<img src="@Herramientas.Ficheros.Imagenes.ServidorExterno(curator.Imagen)"
					 style="width: 100px; height: 100px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 8px 24px rgba(0,0,0,0.3);"
					 alt="@curator.Nombre" />

				<div style="display: flex; flex-direction: column; gap: 10px; padding: 20px;">
					<h1 style="font-size: 18px; margin: 0px; width: fit-content;">
						@if (curator.Web != null)
						{
							<a href="@curator.Web.Enlace" target="_blank" style="text-decoration: none;">@curator.Nombre</a>
						}
						else
						{
							@curator.Nombre
						}
					</h1>
				</div>
			</div>
		</div>
	</div>

	<div class="subcabecera" style="background: color-mix(in srgb, var(--fondoSubcabecera) 45%, var(--fondoBotonPequeño)); position: sticky; top: var(--alturaCabecera); z-index: 100;">
		<div class="cuerpo-ancho" style="display: flex; align-items: center; gap: 30px; padding: 10px 0px;">
			@{
				string scroll1 = "destacados";
				string scroll2 = "filtro";
			}

			<button @onclick="(e => ScrollHastaElemento(e, scroll1))" class="boton-pequeño" style="background: transparent; width: fit-content; box-shadow: none;">
				@Herramientas.Idiomas.BuscarTexto(idioma, "String1", "Curators")
			</button>	

			<button @onclick="(e => ScrollHastaElemento(e, scroll2))" class="boton-pequeño" style="background: transparent; width: fit-content; box-shadow: none;">
				@Herramientas.Idiomas.BuscarTexto(idioma, "String6", "Curators")
			</button>
		</div>
	</div>

	<div class="cuerpo-ancho" style="display: flex; flex-direction: column; gap: 40px; margin: 40px auto;">
		<div id="destacados">
			@if (juegosDestacados.Count > 0)
			{
				<div style="display: flex; flex-direction: column; gap: 40px;">
					@foreach (var destacado in juegosDestacados)
					{
						<div>
							<div style="font-size: 18px; padding: 10px;">
								@destacado.Nombre
							</div>

							<div class="caja-curator-contenido" style="display: flex; align-items: start;">
								<video class="video-autoplay" data-video-id="@destacado.Id"
									   style="width: 100%; height: calc(100vh - 190px); max-height: 500px;"
									   muted loop playsinline>
									<source src="@destacado.Media.Videos[0].Micro" type="video/mp4" />
								</video>

								<div>
									<img src="@destacado.Imagenes.Header_460x215" />
								</div>
							</div>
						</div>
					}
				</div>
				

				<div class="caja-curator-contenido">
					<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 20px; width: 100%; padding: 30px;">
						@foreach (var destacado in juegosDestacados)
						{
							<CajaJuego idioma="@idioma" juego="@destacado" juegosUsuarioIndex="@juegosUsuarioIndex" usuarioDeseadosImportados="@deseadosImportadosIndex" usuarioDeseadosWeb="@deseadosWebIndex" tipo="CajaJuego.Tipo.CuratorDestacado" userAgent="@userAgent" />
						}
					</div>
				</div>
			}
		</div>
		
		<div id="filtro">
			@if (juegosCurator?.Count > 0)
			{
				<div style="display: flex; align-items: start; gap: 40px;">
					@if (Herramientas.Bots.UserAgentEsBot(userAgent) == false && filtrosCurator?.Count > 0)
					{
						<div class="caja-curator-contenido" style="width: 30%; display: flex; flex-direction: column;">
							<div class="caja-curator-titulo">
								@Herramientas.Idiomas.BuscarTexto(idioma, "String6", "Curators")
							</div>

							<div style="padding: 20px; display: flex; flex-direction: column; gap: 5px;">
								@{
									var infoFiltros = new[]
									{
										(JuegoTipo.Game, "String2"),
										(JuegoTipo.DLC, "String3"),
										(JuegoTipo.Music, "String4"),
										(JuegoTipo.Software, "String5")
									};
								}

								@foreach (var (tipo, textoKey) in infoFiltros)
								{
									var filtro = filtrosCurator[tipo];
                
									@if (filtro.juegos.Count > 0)
									{
										<button @onclick="(e => MostrarListado(e, tipo))"
												style="color: var(--colorTexto); border: 0px; width: 100%; text-align: center; padding: 10px; @filtro.ObtenerEstilo()">
											<div style="display: flex; align-items: center;">
												@Herramientas.Idiomas.BuscarTexto(idioma, textoKey, "Curators") (@filtro.juegos.Count)
											</div>
										</button>
									}
								}
							</div>
						</div>
					}

					<div style="width: 100%;">
						<div style="display: flex; flex-direction: column; gap: 20px; margin-top: -20px;">
							<Virtualize Context="juego" Items="juegosCuratorMostrar" ItemSize="107" OverscanCount="6">
								<ItemContent>
									<CajaJuego idioma="@idioma" juego="@juego" juegosUsuarioIndex="@juegosUsuarioIndex" usuarioDeseadosImportados="@deseadosImportadosIndex" usuarioDeseadosWeb="@deseadosWebIndex" tipo="CajaJuego.Tipo.CuratorLista" userAgent="@userAgent" />
								</ItemContent>
							</Virtualize>
						</div>
					</div>
				</div>
			}
		</div>
	</div>	
}

@code {

	#nullable disable

	private string idioma = "en";
	private string usuarioId = null;
	private string userAgent = null;
	private string dominio = null;

	[PersistentState] public Herramientas.UsuarioListadosJuegos juegosUsuario { get; set; }
	[PersistentState] public Herramientas.UsuarioJuegosIndex juegosUsuarioIndex { get; set; }

	[PersistentState] public Usuario deseadosUsuario { get; set; }
	[PersistentState] public Herramientas.UsuarioDeseadosImportadosIndex deseadosImportadosIndex { get; set; }
	[PersistentState] public Herramientas.UsuarioDeseadosWebIndex deseadosWebIndex { get; set; }

	private bool usuarioPatreon = false;
	private TiendaRegion usuarioRegion = TiendaRegion.Europa;

	[Parameter]
	public string slug { get; set; }

	[PersistentState] public BaseDatos.Curators.Curator curator { get; set; }
	[PersistentState] public List<Juegos.Juego> juegosCurator { get; set; }
	private List<Juegos.Juego> juegosDestacados = new List<Juegos.Juego>();

	protected override async Task OnInitializedAsync()
	{
		Herramientas.ContextoUsuarioDatos datos = Herramientas.ContextoUsuario.Leer(Contexto);
		idioma = datos.Idioma;
		usuarioId = datos.UsuarioId;
		userAgent = datos.UserAgent;
		dominio = datos.Dominio;
		usuarioRegion = datos.Region;

		if (string.IsNullOrEmpty(usuarioId) == false)
		{
			idioma = await BaseDatos.Usuarios.Buscar.IdiomaSobreescribir(usuarioId);

			juegosUsuario ??= await Herramientas.UsuarioJuegos.Cargar(usuarioId);
			juegosUsuarioIndex = Herramientas.UsuarioJuegos.CrearIndex(juegosUsuario);

			deseadosUsuario ??= await BaseDatos.Usuarios.Buscar.DeseadosTiene(usuarioId);
			deseadosImportadosIndex = Herramientas.Deseados.CrearImportadosIndex(deseadosUsuario);
			deseadosWebIndex = Herramientas.Deseados.CrearWebIndex(deseadosUsuario);

			usuarioPatreon = Herramientas.Patreon.VerificarActivo(await BaseDatos.Usuarios.Buscar.FechaPatreon(usuarioId));
			usuarioRegion = (TiendaRegion)await BaseDatos.Usuarios.Buscar.OpcionInt(usuarioId, "Currency");
		}

		if (string.IsNullOrEmpty(slug) == false)
		{
			curator ??= await BaseDatos.Curators.Buscar.Uno(slug);
		}

		if (curator?.IdSteam > 0)
		{
			if (string.IsNullOrEmpty(curator.ImagenFondo) == true)
			{
				SteamCuratorAPIVanidad api = await APIs.Steam.Curator.ExtraerVanidad(curator.IdSteam.ToString());

				if (api != null)
				{
					if (string.IsNullOrEmpty(api.Imagen) == false)
					{
						BaseDatos.Curators.Actualizar.ImagenFondo(api.Imagen, curator.IdSteam);
						curator.ImagenFondo = api.Imagen;
					}
				}
			}

			if (curator.Fecha == null)
			{
				global::BaseDatos.Curators.Actualizar.Ejecutar(curator);
			}
			else
			{
				if (curator.Fecha?.Subtract(DateTime.Now) > TimeSpan.FromDays(90))
				{
					global::BaseDatos.Curators.Actualizar.Ejecutar(curator);
				}
			}

			juegosCurator ??= await global::BaseDatos.Juegos.Buscar.MultiplesJuegosSteam2(usuarioRegion, curator.SteamIds);

			if (juegosCurator.Count > 0)
			{
				InicializarFiltros();

				if (juegosCurator.Count > 0)
				{
					List<Juegos.Juego> destacados = new();

					foreach (var juego in juegosCurator)
					{
						if (filtrosCurator.ContainsKey(juego.Tipo) == true)
						{
							filtrosCurator[juego.Tipo].juegos.Add(juego);

							if (juego.Tipo == JuegoTipo.Game && destacados.Count < 6)
							{
								destacados.Add(juego);
							}
						}
					}

					juegosDestacados = destacados;

					var orden = new[] { JuegoTipo.Game, JuegoTipo.DLC, JuegoTipo.Music, JuegoTipo.Software };
					foreach (var tipo in orden)
					{
						if (filtrosCurator[tipo].juegos.Count > 0)
						{
							filtrosCurator[tipo].activo = true;
							break;
						}
					}
				}
			}
		}

		await InvokeAsync(StateHasChanged);
	}

	protected override async Task OnAfterRenderAsync(bool primerRender)
	{
		if (primerRender == true)
		{
			await JavaScript.InvokeVoidAsync("setupVideoAutoplay");
		}
	}

	private void MostrarListado(MouseEventArgs e, JuegoTipo tipo)
	{
		if (filtrosCurator[tipo].activo == true)
		{
			foreach (var filtro in filtrosCurator.Values)
			{
				filtro.activo = false;
			}
		}
		else
		{
			foreach (var filtro in filtrosCurator.Values)
			{
				filtro.activo = false;
			}

			filtrosCurator[tipo].activo = true;
		}
	}

	private class FiltroCurator
	{
		public JuegoTipo tipo { get; set; }
		public bool activo { get; set; }
		public List<global::Juegos.Juego> juegos { get; set; } = new();

		public string ObtenerEstilo()
		{
			return activo ? "background-color: var(--fondoBotonPequeño);" : "background-color: transparent;";
		}
	}

	private Dictionary<JuegoTipo, FiltroCurator> filtrosCurator;

	private void InicializarFiltros()
	{
		filtrosCurator = new Dictionary<JuegoTipo, FiltroCurator>
		{
			[JuegoTipo.Game] = new() { tipo = JuegoTipo.Game },
			[JuegoTipo.DLC] = new() { tipo = JuegoTipo.DLC },
			[JuegoTipo.Music] = new() { tipo = JuegoTipo.Music },
			[JuegoTipo.Software] = new() { tipo = JuegoTipo.Software }
		};
	}

	private List<Juegos.Juego> juegosCuratorMostrar
	{
		get
		{
			var filtroActivo = filtrosCurator?.Values.FirstOrDefault(f => f.activo);
			return filtroActivo?.juegos ?? new List<Juegos.Juego>();
		}
	}

	#region Barra superior

	private async Task ScrollHastaElemento(MouseEventArgs e, string div)
	{
		await JavaScript.InvokeVoidAsync("eval", @"
			const element = document.getElementById('" + div + @"');
			const elementPosition = element.getBoundingClientRect().top;
			const offsetPosition = elementPosition + window.pageYOffset - 130;

			window.scrollTo({
				top: offsetPosition,
				behavior: 'smooth'
			});
		");
	}

	#endregion
}

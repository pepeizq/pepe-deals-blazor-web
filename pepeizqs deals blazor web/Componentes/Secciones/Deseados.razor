	private async Task CargarSuscripciones(List<JuegoSuscripcion> suscripciones, List<JuegoDeseadoMostrar> deseados)
	{
		deseadosSuscripciones ??= new List<JuegoDeseadoMostrar>();
		suscripcionesCache ??= new Dictionary<int, JuegoSuscripcion>();

		if (suscripciones?.Count == 0) 
		{
			return;
		}

		deseadosSuscripciones.Clear();

		HashSet<int> suscripcionesCargar = new HashSet<int>();

		foreach (var juegoSuscripcion in suscripciones)
		{
			JuegoDeseadoMostrar deseado = deseados.FirstOrDefault(d => d.Id == juegoSuscripcion.JuegoId && d.DRM == juegoSuscripcion.DRM);

			if (deseado != null && Suscripciones2.SuscripcionesCargar.DevolverSuscripcion(juegoSuscripcion.Tipo).ParaSiempre == true)
			{
				JuegoDeseadoMostrar nuevoDeseado = new JuegoDeseadoMostrar
				{
					Id = deseado.Id,
					Nombre = deseado.Nombre,
					IdSuscripcion = juegoSuscripcion.Id,
					DRM = deseado.DRM,
					Imagen = deseado.Imagen,
					Importado = deseado.Importado
				};

				if (deseadosSuscripciones.Any(x => x.Id == nuevoDeseado.Id && x.DRM == nuevoDeseado.DRM && x.IdSuscripcion == nuevoDeseado.IdSuscripcion) == false)
				{
					deseadosSuscripciones.Add(nuevoDeseado);
					suscripcionesCargar.Add(juegoSuscripcion.Id);
				}
			}
		}

		if (suscripcionesCargar.Count > 0)
		{
			var idsArray = suscripcionesCargar.ToArray();
			var tareasSuscripcion = idsArray.Select(id => BaseDatos.Suscripciones.Buscar.Id(id)).ToList();
			var resultados = await Task.WhenAll(tareasSuscripcion);

			for (int i = 0; i < idsArray.Length; i++)
			{
				if (resultados[i] != null)
				{
					suscripcionesCache[idsArray[i]] = resultados[i];
				}
			}
		}
	}


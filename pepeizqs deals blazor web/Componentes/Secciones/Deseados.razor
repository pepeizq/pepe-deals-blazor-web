																@Herramientas.Idiomas.BuscarTexto(idioma, "String22", "Wishlist")
															</button>
														</div>
													}
												</Authorized>
											</AuthorizeView>
										</div>
									}
								</ItemContent>
							</Virtualize>
						</div>
					}
				}
			</div>
		}
	}

@code {

	#nullable disable

	private string idioma = "en";
	private string usuarioId = null;
	private string dominio = null;

	private bool usuarioPatreon = false;
	private TiendaRegion usuarioRegion = TiendaRegion.Europa;

	public Usuario opciones { get; set; }
	[PersistentState] public DateTime ultimaVisita { get; set; }

	[Parameter]
	public string perfilUsuarioId { get; set; }

	[PersistentState] public int pestañaMostrar { get; set; }

	[PersistentState] public List<JuegoDeseadoMostrar> deseadosGestor { get; set; }
	public List<JuegoDeseadoMostrar> deseadosOfertas = new List<JuegoDeseadoMostrar>();
	public List<JuegoDeseadoMostrar> deseadosHistoricos = new List<JuegoDeseadoMostrar>();
	[PersistentState] public List<JuegoDeseadoMostrar> deseadosBundles { get; set; }
	[PersistentState] public List<JuegoDeseadoMostrar> deseadosSuscripciones { get; set; }

	public List<Bundles2.Bundle> bundlesActuales { get; set; }
	public List<JuegoSuscripcion> suscripcionesActuales { get; set; }

	private string ordenamientoElegido = string.Empty;

	private bool cargado = false;

	[PersistentState] public Dictionary<int, Bundles2.Bundle> bundlesCache { get; set; }
	[PersistentState] public Dictionary<int, JuegoSuscripcion> suscripcionesCache { get; set; }

	protected override async Task OnInitializedAsync()
	{
		Herramientas.ContextoUsuarioDatos datos = Herramientas.ContextoUsuario.Leer(Contexto);
		idioma = datos.Idioma;
		usuarioId = datos.UsuarioId;
		dominio = datos.Dominio;
		usuarioRegion = datos.Region;

		if (string.IsNullOrEmpty(usuarioId) == false)
		{
			Task<string> tareaIdioma = BaseDatos.Usuarios.Buscar.IdiomaSobreescribir(usuarioId);
			Task<DateTime?> tareaPatreon = BaseDatos.Usuarios.Buscar.FechaPatreon(usuarioId);
			Task<Usuario> tareaUsuario = (opciones != null) ? Task.FromResult(opciones) : BaseDatos.Usuarios.Buscar.OpcionesDeseados(usuarioId);
			Task<List<Bundles2.Bundle>> tareaBundles = (bundlesActuales != null) ? Task.FromResult(bundlesActuales) : BaseDatos.Bundles.Buscar.Actuales();
			Task<List<JuegoSuscripcion>> tareaSuscripciones = (suscripcionesActuales != null) ? Task.FromResult(suscripcionesActuales) : BaseDatos.Suscripciones.Buscar.Actuales();

			await Task.WhenAll(tareaIdioma, tareaPatreon, tareaUsuario, tareaBundles, tareaSuscripciones);

			idioma = tareaIdioma.Result;
			usuarioPatreon = Herramientas.Patreon.VerificarActivo(tareaPatreon.Result);
			opciones = tareaUsuario.Result;
			bundlesActuales ??= tareaBundles.Result;
			suscripcionesActuales ??= tareaSuscripciones.Result;

			if (string.IsNullOrEmpty(perfilUsuarioId) == true)
			{
				await CargarWishlistData(opciones);
			}

			if (opciones?.Currency.HasValue == true)
			{
				usuarioRegion = (TiendaRegion)opciones.Currency.Value;
			}

			if (opciones?.WishlistPosition.HasValue == true)
			{
				pestañaMostrar = (int)opciones.WishlistPosition.Value;
			}
            else
            {
                pestañaMostrar = 1;
            }

			await CambiarPestañaFondo(pestañaMostrar);

			deseadosGestor ??= await Herramientas.Deseados.LeerJuegos(usuarioRegion, usuarioId);

			if (deseadosGestor?.Count > 0)
			{
				if (opciones?.WishlistSort.HasValue == false)
				{
					opciones.WishlistSort = 3;
				}

				await ElegirOrdenamiento();

				bundlesCache ??= new Dictionary<int, Bundles2.Bundle>();
				suscripcionesCache ??= new Dictionary<int, JuegoSuscripcion>();

				await CargarBundles(bundlesActuales ?? new List<Bundles2.Bundle>(), deseadosGestor);
				await CargarSuscripciones(suscripcionesActuales ?? new List<JuegoSuscripcion>(), deseadosGestor);

				ServicioOpciones.OnMostrarOpcionesChanged += StateHasChanged;

				StateHasChanged();
			}

			cargado = true;
		}

		if (string.IsNullOrEmpty(perfilUsuarioId) == false)
		{
			usuarioId = perfilUsuarioId;
		}
	}

	private IJSObjectReference moduloJs;

	protected override async Task OnAfterRenderAsync(bool primerRender)
	{
		if (primerRender == true)
		{
			moduloJs = await JavaScript.InvokeAsync<IJSObjectReference>("import", "/componentes/secciones/Deseados.razor.js");
		}
	}

	public async ValueTask DisposeAsync()
	{
		ServicioOpciones.OnMostrarOpcionesChanged -= StateHasChanged;

		if (moduloJs != null)
		{
			try
			{
				await moduloJs.DisposeAsync();
			}
			catch (JSDisconnectedException)
			{

			}
		}
	}

	#region Inicio

	private async Task CargarBundles(List<Bundles2.Bundle> bundles, List<JuegoDeseadoMostrar> deseados)
	{
		deseadosBundles ??= new List<JuegoDeseadoMostrar>();
		bundlesCache ??= new Dictionary<int, Bundles2.Bundle>();

		if (bundles?.Count == 0) 
		{
			return;
		}

		deseadosBundles.Clear();

		HashSet<int> bundlesCargar = new HashSet<int>();

		foreach (var bundle in bundles)
		{
			foreach (var bundleJuego in bundle.Juegos)
			{
				JuegoDeseadoMostrar deseado = deseados.FirstOrDefault(d => d.Id.ToString() == bundleJuego.JuegoId && d.DRM == bundleJuego.DRM);

				if (deseado != null)
				{
					JuegoDeseadoMostrar nuevoDeseado = new JuegoDeseadoMostrar
					{
						Id = deseado.Id,
						Nombre = deseado.Nombre,
						IdBundle = bundle.Id,
						DRM = deseado.DRM,
						Imagen = deseado.Imagen,
						Importado = deseado.Importado
					};

					if (deseadosBundles.Any(x => x.Id == nuevoDeseado.Id && x.DRM == nuevoDeseado.DRM && x.IdBundle == nuevoDeseado.IdBundle) == false)
					{
						deseadosBundles.Add(nuevoDeseado);
						bundlesCargar.Add(bundle.Id);
					}
				}
			}
		}

		if (bundlesCargar.Count > 0)
		{
			var idsArray = bundlesCargar.ToArray();
			var tareasBundle = idsArray.Select(bundleId => BaseDatos.Bundles.Buscar.UnBundle(bundleId)).ToList();
			var resultados = await Task.WhenAll(tareasBundle);

			for (int i = 0; i < idsArray.Length; i++)
			{
				if (resultados[i] != null)
				{

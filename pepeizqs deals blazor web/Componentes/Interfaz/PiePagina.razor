<style>
    :root {
        --colorEncabezadoPie: #e3eeff;
    }

    .pie2 {
        background-color: color-mix(in srgb, var(--fondoOscuro) 80%, var(--fondoCuerpo));
        font-size: var(--tamañoTexto);
        color: var(--colorTexto);
        border-top: 1px solid rgba(0,255,255,0.15);
    }

    .subir-arriba2 {
        transition: transform 0.2s ease;
    }

    .subir-arriba2:hover {
        transform: scale(105%);
    }
</style>

<footer class="pie2">
    <div style="padding: 30px; max-width: 1600px;">
        <div style="font-size: 16px; display: grid; align-items: stretch; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px;">
            <div style="display: flex; flex-direction: column; gap: 6px; width: 100%;">
                <div style="color: var(--colorEncabezadoPie);">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String1", "Footer")
                </div>

                @if (string.IsNullOrEmpty(usuarioId) == false)
                {
                    <a href="/wishlist" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String2", "Footer")</a>
                }

                <a href="/historical-lows" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String3", "Footer")</a>
                <a href="/bundles" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String4", "Footer")</a>
                <a href="/free" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String5", "Footer")</a>
                <a href="/subscriptions" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String6", "Footer")</a>
                <a href="/streaming" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String26", "Footer")</a>
                <a href="/last-news" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String7", "Footer")</a>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px; width: 100%;">
                <div style="color: var(--colorEncabezadoPie);">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String8", "Footer")
                </div>

                <a href="https://pepeizqapps.com/extension/pepeizq-deals" style="text-decoration: none; line-height: 26px;" target="_blank">@Herramientas.Idiomas.BuscarTexto(idioma, "String10", "Footer")</a>
                <a href="/compare" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String9", "Footer")</a>
                <a href="/filter" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String15", "Footer")</a>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px; width: 100%;">
                <div style="color: var(--colorEncabezadoPie);">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String11", "Footer")
                </div>

                <a href="/contact" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String12", "Footer")</a>
                <a href="/privacy" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String13", "Footer")</a>
                <a href="/cost-web" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String14", "Footer")</a>
                <a href="/regions" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String27", "Footer")</a>
                <a href="/last-updates" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String25", "Footer")</a>
                <a href="/last-added" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String21", "Footer")</a>
                <a href="/patreon" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String24", "Footer")</a>
            </div>

            <div style="display: flex; flex-direction: column; gap: 6px; width: 100%;">
                <div style="color: var(--colorEncabezadoPie);">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String16", "Footer")
                </div>

                <a href="/api" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String17", "Footer")</a>
                <a href="https://github.com/pepeizq/pepe-deals-blazor-web" target="_blank" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String18", "Footer")</a>
                <a href="https://github.com/pepeizq/pepe-deals-extension" target="_blank" style="text-decoration: none; line-height: 26px;">@Herramientas.Idiomas.BuscarTexto(idioma, "String19", "Footer")</a>
            </div>

            <div style="width: 100%; display: flex; align-items: center; justify-content: center;">
                <button onclick="moverScroll('cuerpazo')" class="subir-arriba2" style="text-decoration: none; cursor: pointer; border: 0px; width: fit-content; background-color: var(--fondoBotonPequeño); padding: 10px; border: 1px solid rgba(0,255,255,0.15);" title="@Herramientas.Idiomas.BuscarTexto(idioma, "String20", "Footer")">
                    <div style="width: 40px; height: 40px;">
                        <svg style="fill: var(--colorTexto);" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                            <path d="M297.4 169.4C309.9 156.9 330.2 156.9 342.7 169.4L534.7 361.4C547.2 373.9 547.2 394.2 534.7 406.7C522.2 419.2 501.9 419.2 489.4 406.7L320 237.3L150.6 406.6C138.1 419.1 117.8 419.1 105.3 406.6C92.8 394.1 92.8 373.8 105.3 361.3L297.3 169.3z" />
                        </svg>
                    </div>
                </button>
            </div>
        </div>

        <hr style="margin: 30px 0;" />

        <div style="display: flex; align-items: start; gap: 40px; font-size: 14px; color: color-mix(in srgb, var(--colorTexto) 60%, var(--fondoBotonPequeño));">
            <div style="display: flex; flex-direction: column; gap: 10px; max-width: 70%;">
                <div>
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String22", "Footer")
                </div>

                <div>
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String23", "Footer")
                </div>

                <div>
                    &copy; @DateTime.Now.Year.ToString() • <a href="https://pepeizqapps.com/" style="text-decoration: none; line-height: 26px;" target="_blank">pepeizq's apps</a>
                </div>
            </div>

            <div style="margin-left: auto; display: flex; align-items: center; gap: 20px;">
                <RedesSociales idioma="@idioma" />
            </div>
        </div>
    </div>
</footer>

@code {

    #nullable disable

    [Parameter]
    public string idioma { get; set; }

    [Parameter]
    public string usuarioId { get; set; }
}

@using Noticias

@implements IAsyncDisposable

@inject IJSRuntime JavaScript

<div @key="@noticia.Id" class="tooltip-juego" id="trigger-@idTooltip"
	 @onmouseenter="@(() => ActivarTooltip($"trigger-{idTooltip}", $"tooltip-{idTooltip}"))"
	 @onmouseleave="@(() => DesactivarTooltip($"trigger-{idTooltip}"))" style="width: 100%; display: flex; align-items: center; flex: 0 0 400px;">
	<a href="/news/@noticia.Id/@Herramientas.EnlaceAdaptador.Nombre(titulo)/" style="cursor: pointer; text-decoration: none; color: var(--colorTexto); height: 100%;">
		<div class="cnoticia-expandir" title="@titulo">
			<div style="display: flex; align-items: center; gap: 15px; background-color: var(--fondoBotonPequeño); padding: 15px 20px; width: 100%;">
				@{
					string icono = string.Empty;
					string etiqueta = string.Empty;

					if (noticia.NoticiaTipo == NoticiaTipo.Bundles)
					{
						icono = Bundles2.BundlesCargar.DevolverBundle(noticia.BundleTipo).ImagenIcono;
						etiqueta = Herramientas.Idiomas.BuscarTexto(idioma, "Type2", "News");
					}
					else if (noticia.NoticiaTipo == NoticiaTipo.Gratis)
					{
						icono = Gratis2.GratisCargar.DevolverGratis(noticia.GratisTipo).ImagenIcono;
						etiqueta = Herramientas.Idiomas.BuscarTexto(idioma, "Type3", "News");
					}
					else if (noticia.NoticiaTipo == NoticiaTipo.Suscripciones)
					{
						icono = Suscripciones2.SuscripcionesCargar.DevolverSuscripcion(noticia.SuscripcionTipo).ImagenIcono;
						etiqueta = Herramientas.Idiomas.BuscarTexto(idioma, "Type4", "News");
					}
					else if (noticia.NoticiaTipo == NoticiaTipo.Web)
					{
						icono = "/favicons/favicon-96x96.webp";
						etiqueta = Herramientas.Idiomas.BuscarTexto(idioma, "Type9", "News");
					}

					if (string.IsNullOrEmpty(icono) == false)
					{
						string icono1 = icono.Replace(".webp", "-sm.webp");
						string icono2 = icono.Replace(".webp", "-md.webp");

						<div style="display: flex;">
							<picture>
								<source srcset="@icono1 1x, @icono2 2x" type="image/webp">
								<img src="@icono" style="width: 18px; height: 18px; aspect-ratio: 1/1;" alt="@Noticias.NoticiasCargar.Traduccion(noticia.NoticiaTipo, idioma)" />
							</picture>
						</div>
					}

					if (string.IsNullOrEmpty(etiqueta) == false)
					{
						<div style="font-size: 14px;">
							@etiqueta
						</div>
					}
				}

				<div style="font-size: 14px; margin-left: auto;">
					@mensajeTiempo
				</div>
			</div>

			<div class="noticia-borrado" style="height: 100%;">
				<img src="@Herramientas.Ficheros.Imagenes.ServidorExterno(noticia.Imagen)" onerror="this.closest('.noticia-borrado').classList.add('img-error')" style="width: 100%; height: 100%; object-fit: contain;" alt="@titulo" />
			
				<span class="mensaje-alternativo" style="padding: 20px; text-align: center;">@titulo</span>
			</div>
		</div>
	</a>

	<div id="tooltip-@idTooltip" class="tooltip-relleno">
		<div style="margin: 8px; max-width: 300px; font-size: 14px;">
			@titulo
		</div>
	</div>
</div>

@code {

	#nullable disable

	[Parameter]
	public string idioma { get; set; }

	[Parameter]
	public Noticias.Noticia noticia { get; set; }

	[Parameter]
	public Tipo tipo { get; set; } = Tipo.Desconocido;

	public enum Tipo
	{
		Desconocido,
		Portada,
		UltimasNoticias
	}

	private string titulo = string.Empty;
	private string mensajeTiempo = string.Empty;
    private string idTooltip => $"news-{noticia?.Id.ToString()}";

	private IJSObjectReference moduloJs;

	protected override async Task OnAfterRenderAsync(bool primerRender)
	{
		if (primerRender == true)
		{
			moduloJs = await JavaScript.InvokeAsync<IJSObjectReference>("import", "/componentes/interfaz/CajaNoticia.razor.js");
		}

		titulo = Herramientas.Idiomas.ElegirTexto(idioma, noticia.TituloEn, noticia.TituloEs);
		mensajeTiempo = Herramientas.Calculadora.DiferenciaTiempo(noticia.FechaEmpieza, idioma);
	}

	public async ValueTask DisposeAsync()
	{
		if (moduloJs != null)
		{
			try
			{
				await moduloJs.DisposeAsync();
			}
			catch { }
		}
	}

	private async Task ActivarTooltip(string triggerId, string tooltipId)
	{
		if (moduloJs != null)
		{
			await moduloJs.InvokeVoidAsync("activarTooltip", triggerId, tooltipId);
		}
	}

	private async Task DesactivarTooltip(string triggerId)
	{
		if (moduloJs != null)
		{
			await moduloJs.InvokeVoidAsync("desactivarTooltip", triggerId);
		}
	}
}

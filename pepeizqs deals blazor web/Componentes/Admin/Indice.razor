        nuevosErroresCantidad = await BaseDatos.Admin.Buscar.CantidadErrores();

        if (moduloJs != null)
        {
            await moduloJs.InvokeVoidAsync("cambiarEnlace", "/admin/" + subpaginaErrores + "/");
        }
    }


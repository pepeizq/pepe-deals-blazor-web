@using BaseDatos.Pendientes
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Data.SqlClient
@using Tiendas2
@using global::Juegos

<style>
    .caja-admin-pendientes {
        background-color: var(--fondoSubsubcabecera);
        border: 2px solid var(--fondoSubcabecera);
        padding: 30px;
        box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.28),0px 0px 2px 0px rgba(0, 0, 0, 0.24);
    }
</style>

<div class="caja-admin-pendientes" style="display: flex; justify-content: space-between; flex-direction: row; gap: 40px;">
    <div style="min-width: 300px; margin: -10px 0px;">
        @foreach (var pendiente in pendientesTiendas)
        {
            if (pendiente.Pendientes.Count > 0)
            {
                string fondo = string.Empty;

                if (string.IsNullOrEmpty(idTiendaPendiente) == true && string.IsNullOrEmpty(idSuscripcionPendiente) == true && string.IsNullOrEmpty(idStreamingPendiente) == true && string.IsNullOrEmpty(idPlataformaPendiente) == true)
                {
                    idTiendaPendiente = pendiente.Tienda.Id;
                }
                else
                {
                    if (idTiendaPendiente != pendiente.Tienda.Id)
                    {
                        fondo = "background-color: transparent;";
                    }
                }

                <button @onclick="@(e => ClickearTiendaPendientes(e, pendiente.Tienda.Id, pendiente.Tienda.Nombre))" class="boton-pequeño" style="margin: 10px 0px; display: block; box-shadow: none; @fondo">
                    <img src="@pendiente.Tienda.ImagenIcono" style="margin: 0px 8px; height: 16px; width: 16px;" /> @pendiente.Tienda.Nombre (@pendiente.Pendientes.Count)
                </button>
            }
        }

        @foreach (var pendiente in pendientesSuscripcion)
        {
            if (pendiente.Pendientes.Count > 0)
            {
                string fondo = string.Empty;

                if (string.IsNullOrEmpty(idTiendaPendiente) == true && string.IsNullOrEmpty(idSuscripcionPendiente) == true && string.IsNullOrEmpty(idStreamingPendiente) == true && string.IsNullOrEmpty(idPlataformaPendiente) == true)
                {
                    idSuscripcionPendiente = pendiente.Suscripcion.Id.ToString();
                }
                else
                {
                    if (idSuscripcionPendiente != pendiente.Suscripcion.Id.ToString())
                    {
                        fondo = "background-color: transparent;";
                    }
                }

                <button @onclick="@(e => ClickearSuscripcionPendientes(e, pendiente.Suscripcion.Id.ToString(), pendiente.Suscripcion.Nombre))" class="boton-pequeño" style="margin: 10px 0px; display: block; box-shadow: none; @fondo">
                    <img src="@pendiente.Suscripcion.ImagenIcono" style="margin: 0px 8px; height: 16px; width: 16px;" /> @pendiente.Suscripcion.Nombre (@pendiente.Pendientes.Count)
                </button>
            }
        }

        @foreach (var pendiente in pendientesStreaming)
        {
            if (pendiente.Pendientes.Count > 0)
            {
                string fondo = string.Empty;

                if (string.IsNullOrEmpty(idTiendaPendiente) == true && string.IsNullOrEmpty(idSuscripcionPendiente) == true && string.IsNullOrEmpty(idStreamingPendiente) == true && string.IsNullOrEmpty(idPlataformaPendiente) == true)
                {
                    idStreamingPendiente = pendiente.Streaming.Id.ToString();
                }
                else
                {
                    if (idStreamingPendiente != pendiente.Streaming.Id.ToString())
                    {
                        fondo = "background-color: transparent;";
                    }
                }

                <button @onclick="@(e => ClickearStreamingPendientes(e, pendiente.Streaming.Id.ToString(), pendiente.Streaming.Nombre))" class="boton-pequeño" style="margin: 10px 0px; display: block; box-shadow: none; @fondo">
                    <img src="@pendiente.Streaming.ImagenIcono" style="margin: 0px 8px; height: 16px; width: 16px;" /> @pendiente.Streaming.Nombre (@pendiente.Pendientes.Count)
                </button>
            }
        }

        @foreach (var pendiente in pendientesPlataforma)
        {
            if (pendiente.Pendientes.Count > 0)
            {
                string fondo = string.Empty;

                if (string.IsNullOrEmpty(idTiendaPendiente) == true && string.IsNullOrEmpty(idSuscripcionPendiente) == true && string.IsNullOrEmpty(idStreamingPendiente) == true && string.IsNullOrEmpty(idPlataformaPendiente) == true)
                {
                    idPlataformaPendiente = pendiente.Plataforma.Id.ToString();
                }
                else
                {
                    if (idPlataformaPendiente != pendiente.Plataforma.Id.ToString())
                    {
                        fondo = "background-color: transparent;";
                    }
                }

                <button @onclick="@(e => ClickearPlataformaPendientes(e, pendiente.Plataforma.Id.ToString(), pendiente.Plataforma.Nombre))" class="boton-pequeño" style="margin: 10px 0px; display: block; @fondo">
                    <img src="@pendiente.Plataforma.ImagenIcono" style="margin: 0px 8px; height: 16px; width: 16px;" /> @pendiente.Plataforma.Nombre (@pendiente.Pendientes.Count)
                </button>
            }
        }
    </div>

    @if (string.IsNullOrEmpty(idTiendaPendiente) == false || string.IsNullOrEmpty(idSuscripcionPendiente) == false || string.IsNullOrEmpty(idStreamingPendiente) == false || string.IsNullOrEmpty(idPlataformaPendiente) == false)
    {
        <div style="width: 100%;">
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <div style="display: flex; align-items: center; gap: 30px;">
                    @if (idsPendiente != "0" && ocupado == false)
                    {
                        <button @onclick="@(e => ClickearActualizarPendientes(e, enlacePendiente))" class="boton-pequeño" style="width: 130px; text-align: center;">Actualizar</button>
                    }

                    <button @onclick="@(e => ClickearDescartarPendientes(e, enlacePendiente))" class="boton-pequeño" style="width: 130px; text-align: center; margin-left: auto; background-color: var(--fondoPeligro);">
                        Descartar
                    </button>
                </div>

                <div>
                    <a href="@enlacePendiente" target="_blank" style="text-decoration: none;">@nombrePendiente</a>
                </div>

                <div>
                    <textarea @oninput="TextoCambiaPendientes" class="entrada-texto" style="width: 100%;" value="@idsPendiente" rows="1" />
                </div>

                <div style="display: flex; align-items: start; gap: 20px;">
                    @{
                        string ancho = "max-width: 200px;";
                        
                        if (string.IsNullOrEmpty(idsPendiente) == false)
                        {
                            if (idsPendiente.Split(',').Length > 1)
                            {
                                ancho = "max-width: 120px;";
                            }
                        }
                    }

                    <div style="@ancho">
                        <a href="@enlacePendiente" target="_blank" style="text-decoration: none;">
                            <img src="@imagenPendiente" style="width: 100%;" />
                        </a>
                    </div>

                    <div style="border: 3px solid var(--fondoBotonPequeño); height: 70px;" />

                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 10px;">
                        @if (string.IsNullOrEmpty(idsPendiente) == false)
                        {
                            if (seleccionados?.Count > 0)
                            {
                                foreach (var resultado in seleccionados)
                                {
                                    if (resultado != null)
                                    {
                                        <a href="/game/@resultado.Id" target="_blank" style="text-decoration: none;">
                                            <img src="@resultado.Imagenes.Header_460x215" style="width: 100%; height: 100%; object-fit: cover;" />
                                        </a>
                                    }
                                }
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }  
</div>

<div class="caja-admin-pendientes" style="margin-top: 30px;">
    <div style="margin-bottom: 10px;">
        Buscador:
    </div>

    <input type="text" @bind-value="textoBuscador" @bind-value:event="oninput" @bind-value:after="TextoCambiaBuscador" class="entrada-texto" />

    @if (buscadorBuscando)
    {
        <div style="margin-top: 20px;">
            Buscando...
        </div>
    }
    else if (string.IsNullOrEmpty(textoBuscador) == false)
    {
        @if (pestañasBuscador.Values.All(p => p.resultados.Count == 0))
        {
            <div style="margin-top: 20px;">
                No hay resultados
            </div>
        }
        else
        {
            <div style="display: flex; align-items: center; gap: 20px; margin: 20px 0px;">
                @foreach (var (tipo, info) in ObtenerInfoPestañas())
                {
                    var pestaña = pestañasBuscador[tipo];
                    <button @onclick="@(e => CambiarPestañas(e, info.Indice))" class="boton-pequeño" style="width: @(info.Ancho)px; text-align: center; box-shadow: none; @pestaña.ObtenerEstilo()">
                        @info.Titulo (@pestaña.resultados.Count)
                    </button>
                }
            </div>

            foreach (var pestaña in pestañasBuscador.Values.Where(p => p.activa && p.resultados.Count > 0))
            {
                <div>
                    @foreach (var item in pestaña.resultados)
                    {
                        <hr />
                        <div class="perfil-flexible-centrado" style="flex-wrap: wrap;">
                            <div style="width: 150px; min-width: 150px;">
                                <button @onclick="@(e => ClickearIdPendientes(e, item))" class="boton-pequeño" style="text-align: center;">
                                    Añadir ID

                                    <div style="font-size: 13px;">
                                        @item.Id
                                    </div>
                                </button>
                            </div>

                            <div style="padding-left: 15px;">
                                <a href="/game/@item.Id" target="_blank">
                                    <img src="@item.Imagenes.Header_460x215" style="width: 230px; height: 112px;" />
                                </a>
                            </div>

                            <div style="width: 100%; padding: 5px 10px; flex: 1;">
                                @item.Nombre
                            </div>

                            <div class="admin-busqueda-juego-derecha">
                                <button @onclick="@(e => ClickearBorrarPendientes(e, item.Id.ToString()))" class="boton-pequeño" style="background-color: var(--fondoPeligro); text-align: center;">
                                    Borrar
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
</div>

@code {

    #nullable disable

    private bool ocupado = false;

    private List<PendientesTienda> pendientesTiendas = new List<PendientesTienda>();
    private List<PendientesSuscripcion> pendientesSuscripcion = new List<PendientesSuscripcion>();
    private List<PendientesStreaming> pendientesStreaming = new List<PendientesStreaming>();
    private List<PendientesPlataforma> pendientesPlataforma = new List<PendientesPlataforma>();

    private string idTiendaPendiente = null;
    private string idSuscripcionPendiente = null;
    private string idStreamingPendiente = null;
    private string idPlataformaPendiente = null;

    private string imagenPendiente = null;
    private string nombrePendiente = null;
    private string enlacePendiente = null;
    private string idsPendiente = null;

    protected override async Task OnInitializedAsync()
    {
        ocupado = true;

        InicializarPestañasBuscador();

        #region Tiendas

        pendientesTiendas.Clear();

        foreach (var tienda in Tiendas2.TiendasCargar.GenerarListado())
        {
            if (tienda.Id != APIs.Steam.Tienda.Generar().Id && tienda.Id != APIs.Steam.Tienda.GenerarBundles().Id)
            {
                PendientesTienda pendienteTienda = new PendientesTienda();
                pendienteTienda.Tienda = tienda;
                pendienteTienda.Pendientes = await BaseDatos.Pendientes.Buscar.Tienda(tienda.Id);

                if (pendienteTienda.Pendientes.Count > 0)
                {
                    pendientesTiendas.Add(pendienteTienda);
                }
            }
        }

        if (string.IsNullOrEmpty(idsPendiente) == true && pendientesTiendas?.Count > 0)
        {
            nombrePendiente = pendientesTiendas[0].Pendientes[0].Nombre;
            imagenPendiente = pendientesTiendas[0].Pendientes[0].Imagen;
            enlacePendiente = pendientesTiendas[0].Pendientes[0].Enlace;

            idsPendiente = await BaseDatos.Pendientes.Buscar.IDs(pendientesTiendas[0].Pendientes[0].Nombre);
        }

        #endregion

        #region Suscripciones

        pendientesSuscripcion.Clear();

        foreach (var suscripcion in Suscripciones2.SuscripcionesCargar.GenerarListado())
        {
            if (suscripcion.AdminPendientes == true)
            {
                PendientesSuscripcion pendienteSuscripcion = new PendientesSuscripcion();
                pendienteSuscripcion.Suscripcion = suscripcion;
                pendienteSuscripcion.Pendientes = await BaseDatos.Pendientes.Buscar.Suscripcion(suscripcion.Id);

                if (pendienteSuscripcion.Pendientes.Count > 0)
                {
                    pendientesSuscripcion.Add(pendienteSuscripcion);
                }
            }
        }

        if (string.IsNullOrEmpty(idsPendiente) == true && pendientesSuscripcion?.Count > 0)
        {
            nombrePendiente = pendientesSuscripcion[0].Pendientes[0].Nombre;
            imagenPendiente = pendientesSuscripcion[0].Pendientes[0].Imagen;
            enlacePendiente = pendientesSuscripcion[0].Pendientes[0].Enlace;
            idsPendiente = await BaseDatos.Pendientes.Buscar.IDs(pendientesSuscripcion[0].Pendientes[0].Nombre);
        }

        #endregion

        #region Streaming

        pendientesStreaming.Clear();

        foreach (var streaming in Streaming2.StreamingCargar.GenerarListado())
        {
            PendientesStreaming pendienteStreaming = new PendientesStreaming();
            pendienteStreaming.Streaming = streaming;
            pendienteStreaming.Pendientes = await BaseDatos.Pendientes.Buscar.Streaming(streaming.Id);

            if (pendienteStreaming.Pendientes.Count > 0)
            {
                pendientesStreaming.Add(pendienteStreaming);
            }
        }

        if (string.IsNullOrEmpty(idsPendiente) == true && pendientesStreaming?.Count > 0)
        {
            nombrePendiente = pendientesStreaming[0].Pendientes[0].Nombre;
            imagenPendiente = pendientesStreaming[0].Pendientes[0].Imagen;
            enlacePendiente = pendientesStreaming[0].Pendientes[0].Enlace;
            idsPendiente = await BaseDatos.Pendientes.Buscar.IDs(pendientesStreaming[0].Pendientes[0].Nombre);
        }

        #endregion

        #region Plataformas

        pendientesPlataforma.Clear();

        foreach (var plataforma in Plataformas2.PlataformasCargar.GenerarListado())
        {
            PendientesPlataforma pendientePlataforma = new PendientesPlataforma();
            pendientePlataforma.Plataforma = plataforma;
            pendientePlataforma.Pendientes = await BaseDatos.Pendientes.Buscar.Plataforma(plataforma.Id);

            if (pendientePlataforma.Pendientes.Count > 0)
            {
                pendientesPlataforma.Add(pendientePlataforma);
            }
        }

        if (string.IsNullOrEmpty(idsPendiente) == true && pendientesPlataforma?.Count > 0)
        {
            nombrePendiente = pendientesPlataforma[0].Pendientes[0].Nombre;
            imagenPendiente = pendientesPlataforma[0].Pendientes[0].Imagen;
            enlacePendiente = pendientesPlataforma[0].Pendientes[0].Enlace;
            idsPendiente = await BaseDatos.Pendientes.Buscar.IDs(pendientesPlataforma[0].Pendientes[0].Nombre);
        }

        #endregion

        if (string.IsNullOrEmpty(idsPendiente) == true)
        {
            idsPendiente = "0";
        }
        else if (idsPendiente != "0")
        {
            await AñadirResultados();
        }

        ocupado = false;
    }

    private async Task ClickearTiendaPendientes(MouseEventArgs e, string id, string nombre)
    {
        ocupado = true;

        idTiendaPendiente = id;
        idSuscripcionPendiente = null;
        idStreamingPendiente = null;
        idPlataformaPendiente = null;

        await ClickearTiendaPendientes(idTiendaPendiente);

        ocupado = false;
    }

    private async Task ClickearTiendaPendientes(string id)
    {
        ocupado = true;

        seleccionados.Clear();

        if (string.IsNullOrEmpty(id) == false)
        {
            BaseDatos.Pendientes.Pendiente juego = await BaseDatos.Pendientes.Buscar.PrimerJuegoTienda(id);

            if (juego != null)
            {
                nombrePendiente = juego.Nombre;

                string imagen = juego.Imagen;

                if (imagen != null)
                {
                    imagen = imagen.Replace("&amp;", "&");
                }

                imagenPendiente = imagen;

                enlacePendiente = juego.Enlace;

                idsPendiente = await BaseDatos.Pendientes.Buscar.IDs(nombrePendiente);
                await AñadirResultados();
            }
        }

        ocupado = false;
    }

    private async Task ClickearSuscripcionPendientes(MouseEventArgs e, string id, string nombre)
    {
        ocupado = true;

        idTiendaPendiente = null;
        idSuscripcionPendiente = id;
        idStreamingPendiente = null;
        idPlataformaPendiente = null;

        await ClickearSuscripcionPendientes(idSuscripcionPendiente);

        ocupado = false;
    }

    private async Task ClickearSuscripcionPendientes(string id)
    {
        ocupado = true;

        seleccionados.Clear();

        if (string.IsNullOrEmpty(id) == false)
        {
            BaseDatos.Pendientes.Pendiente juego = await BaseDatos.Pendientes.Buscar.PrimerJuegoSuscripcion(id);

            if (juego != null)
            {
                nombrePendiente = juego.Nombre;

                string imagen = juego.Imagen;

                if (imagen != null)
                {
                    imagen = imagen.Replace("&amp;", "&");
                }

                imagenPendiente = imagen;

                enlacePendiente = juego.Enlace;

                idsPendiente = await BaseDatos.Pendientes.Buscar.IDs(nombrePendiente);
                await AñadirResultados();
            }
        }

        ocupado = false;
    }

    private async Task ClickearStreamingPendientes(MouseEventArgs e, string id, string nombre)
    {
        ocupado = true;

        idTiendaPendiente = null;
        idSuscripcionPendiente = null;
        idStreamingPendiente = id;
        idPlataformaPendiente = null;

        await ClickearStreamingPendientes(idStreamingPendiente);

        ocupado = false;
    }

    private async Task ClickearStreamingPendientes(string id)
    {
        ocupado = true;

        seleccionados.Clear();

        if (string.IsNullOrEmpty(id) == false)
        {
            BaseDatos.Pendientes.Pendiente juego = await BaseDatos.Pendientes.Buscar.PrimerJuegoStreaming(id);

            if (juego != null)
            {
                nombrePendiente = juego.Nombre;

                string imagen = juego.Imagen;

                if (imagen != null)
                {
                    imagen = imagen.Replace("&amp;", "&");
                }

                imagenPendiente = imagen;

                enlacePendiente = juego.Enlace;

                idsPendiente = await BaseDatos.Pendientes.Buscar.IDs(nombrePendiente);
                await AñadirResultados();
            }
        }

        ocupado = false;
    }

    private async Task ClickearPlataformaPendientes(MouseEventArgs e, string id, string nombre)
    {
        ocupado = true;

        idTiendaPendiente = null;
        idSuscripcionPendiente = null;
        idStreamingPendiente = null;
        idPlataformaPendiente = id;

        await ClickearPlataformaPendientes(idPlataformaPendiente);

        ocupado = false;
    }

    private async Task ClickearPlataformaPendientes(string id)
    {
        ocupado = true;

        seleccionados.Clear();

        if (string.IsNullOrEmpty(id) == false)
        {
            BaseDatos.Pendientes.Pendiente juego = await BaseDatos.Pendientes.Buscar.PrimerJuegoPlataforma(id);

            if (juego != null)
            {
                nombrePendiente = juego.Nombre;

                string imagen = juego.Imagen;

                if (imagen != null)
                {
                    imagen = imagen.Replace("&amp;", "&");
                }

                imagenPendiente = imagen;

                if (id.ToLower() == "amazon")
                {
                    enlacePendiente = "amazon-games://play/" + juego.Enlace;
                }
                else
                {
                    enlacePendiente = juego.Enlace;
                }

                idsPendiente = "0";
            }
        }

        ocupado = false;
    }

    private async Task ClickearDescartarPendientes(MouseEventArgs e, string enlace)
    {
        ocupado = true;

        if (string.IsNullOrEmpty(idTiendaPendiente) == false)
        {
            await BaseDatos.Pendientes.Actualizar.DescartarTienda(idTiendaPendiente, enlace);

            foreach (var pendiente in pendientesTiendas)
            {
                if (pendiente.Tienda.Id == idTiendaPendiente)
                {
                    pendiente.Pendientes = await BaseDatos.Pendientes.Buscar.Tienda(idTiendaPendiente);
                }
            }

            await ClickearTiendaPendientes(idTiendaPendiente);
        }

        if (string.IsNullOrEmpty(idSuscripcionPendiente) == false)
        {
            await BaseDatos.Pendientes.Actualizar.DescartarSuscripcion(idSuscripcionPendiente, enlace);

            foreach (var pendiente in pendientesSuscripcion)
            {
                if (pendiente.Suscripcion.Id.ToString() == idSuscripcionPendiente)
                {
                    pendiente.Pendientes = await BaseDatos.Pendientes.Buscar.Suscripcion(pendiente.Suscripcion.Id);
                }
            }

            await ClickearSuscripcionPendientes(idSuscripcionPendiente);
        }

        if (string.IsNullOrEmpty(idStreamingPendiente) == false)
        {
            await BaseDatos.Pendientes.Actualizar.DescartarStreaming(idStreamingPendiente, enlace);

            foreach (var pendiente in pendientesStreaming)
            {
                if (pendiente.Streaming.Id.ToString() == idStreamingPendiente)
                {
                    pendiente.Pendientes = await BaseDatos.Pendientes.Buscar.Streaming(pendiente.Streaming.Id);
                }
            }

            await ClickearStreamingPendientes(idStreamingPendiente);
        }

        if (string.IsNullOrEmpty(idPlataformaPendiente) == false)
        {
            enlace = enlace.Replace("amazon-games://play/", null);

            await BaseDatos.Pendientes.Actualizar.DescartarPlataforma(idPlataformaPendiente, enlace);

            foreach (var pendiente in pendientesPlataforma)
            {
                if (pendiente.Plataforma.Id.ToString() == idPlataformaPendiente)
                {
                    pendiente.Pendientes = await BaseDatos.Pendientes.Buscar.Plataforma(pendiente.Plataforma.Id);
                }
            }

            await ClickearPlataformaPendientes(idPlataformaPendiente);
        }

        ocupado = false;
    }

    private async Task ClickearActualizarPendientes(MouseEventArgs e, string enlace)
    {
        ocupado = true;

        seleccionados.Clear();

        if (string.IsNullOrEmpty(idTiendaPendiente) == false)
        {
            await BaseDatos.Pendientes.Actualizar.Tienda(idTiendaPendiente, enlace, idsPendiente);

            if (idTiendaPendiente != APIs.Steam.Tienda.GenerarBundles().Id)
            {
                List<string> lista = new List<string>();
                string[] datosPartidos = idsPendiente.Split(',');
                lista.AddRange(datosPartidos);

                if (lista.Count > 1)
                {
                    BaseDatos.Pendientes.Insertar.AñadirId(nombrePendiente, idsPendiente);
                }
            }

            foreach (var pendiente in pendientesTiendas)
            {
                if (pendiente.Tienda.Id == idTiendaPendiente)
                {
                    pendiente.Pendientes = await BaseDatos.Pendientes.Buscar.Tienda(idTiendaPendiente);
                }
            }

            await ClickearTiendaPendientes(idTiendaPendiente);
        }

        if (string.IsNullOrEmpty(idSuscripcionPendiente) == false)
        {
            await BaseDatos.Pendientes.Actualizar.Suscripcion(Suscripciones2.SuscripcionesCargar.DevolverSuscripcion(idSuscripcionPendiente).TablaPendientes, "temporal" + idSuscripcionPendiente, enlace, nombrePendiente, imagenPendiente, Herramientas.Listados.Generar(idsPendiente));

            foreach (var pendiente in pendientesSuscripcion)
            {
                if (pendiente.Suscripcion.Id.ToString() == idSuscripcionPendiente)
                {
                    pendiente.Pendientes = await BaseDatos.Pendientes.Buscar.Suscripcion(pendiente.Suscripcion.Id);
                }
            }

            await ClickearSuscripcionPendientes(idSuscripcionPendiente);
        }

        if (string.IsNullOrEmpty(idStreamingPendiente) == false)
        {
            await BaseDatos.Pendientes.Actualizar.Streaming(idStreamingPendiente, enlace, int.Parse(idsPendiente));

            foreach (var pendiente in pendientesStreaming)
            {
                if (pendiente.Streaming.Id.ToString() == idStreamingPendiente)
                {
                    pendiente.Pendientes = await BaseDatos.Pendientes.Buscar.Streaming(pendiente.Streaming.Id);
                }
            }

            await ClickearStreamingPendientes(idStreamingPendiente);
        }

        if (string.IsNullOrEmpty(idPlataformaPendiente) == false)
        {
            if (idPlataformaPendiente.ToLower() == "amazon")
            {
                enlace = enlace.Replace("amazon-games://play/", null);

                await BaseDatos.Pendientes.Actualizar.PlataformaAmazon(enlace, int.Parse(idsPendiente));
            }

            if (idPlataformaPendiente.ToLower() == "epic")
            {
                await BaseDatos.Pendientes.Actualizar.PlataformaEpic(enlace, int.Parse(idsPendiente));
            }

            if (idPlataformaPendiente.ToLower() == "ubisoft")
            {
                await BaseDatos.Pendientes.Actualizar.PlataformaUbisoft(enlace, int.Parse(idsPendiente));
            }

            if (idPlataformaPendiente.ToLower() == "ea")
            {
                await BaseDatos.Pendientes.Actualizar.PlataformaEA(enlace, int.Parse(idsPendiente));
            }

            foreach (var pendiente in pendientesPlataforma)
            {
                if (pendiente.Plataforma.Id.ToString() == idPlataformaPendiente)
                {
                    pendiente.Pendientes = await BaseDatos.Pendientes.Buscar.Plataforma(pendiente.Plataforma.Id);
                }
            }

            await ClickearPlataformaPendientes(idPlataformaPendiente);
        }

        ocupado = false;
    }

    #region Seleccionados

    private List<global::Juegos.Juego> seleccionados = new List<global::Juegos.Juego>();

    private async Task TextoCambiaPendientes(ChangeEventArgs texto)
    {
        ocupado = true;

        idsPendiente = texto.Value.ToString();

        await AñadirResultados();

        ocupado = false;
    }

    private async Task AñadirResultados()
    {
        List<string> lista = new List<string>();
        string[] datosPartidos = idsPendiente.Split(',');
        lista.AddRange(datosPartidos);

        if (seleccionados == null)
        {
            seleccionados = new List<global::Juegos.Juego>();
        }

        if (lista?.Count > 0)
        {
            var idsJuegos = new HashSet<int>(seleccionados?.Select(j => j.Id));

            var noExistentes = lista.Where(id => idsJuegos.Contains(int.Parse(id)) == false).ToList();

            if (noExistentes?.Count > 0)
            {
                foreach (var noExiste in noExistentes)
                {
                    seleccionados.Add(await BaseDatos.Juegos.Buscar.UnJuegoReducido(int.Parse(noExiste)));
                }
            }
        }
    }

    #endregion

    #region Buscador 

    private class PestañaBuscador
    {
        public JuegoTipo tipo { get; set; }
        public bool activa { get; set; }
        public bool visible { get; set; }
        public List<global::Juegos.Juego> resultados { get; set; } = new();

        public string ObtenerEstilo()
        {
            if (visible == false) 
            {
                return "display: none;";
            }

            return activa ? "background-color: var(--fondoBotonPequeño);" : "background-color: transparent;";
        }
    }

    private Dictionary<JuegoTipo, PestañaBuscador> pestañasBuscador;

    private void InicializarPestañasBuscador()
    {
        pestañasBuscador = new Dictionary<JuegoTipo, PestañaBuscador>
        {
            [JuegoTipo.Game] = new() { tipo = JuegoTipo.Game, activa = true, visible = true },
            [JuegoTipo.DLC] = new() { tipo = JuegoTipo.DLC },
            [JuegoTipo.Music] = new() { tipo = JuegoTipo.Music },
            [JuegoTipo.Software] = new() { tipo = JuegoTipo.Software }
        };
    }

    private bool pestañaJuegos => pestañasBuscador[JuegoTipo.Game].activa;
    private bool pestañaDLCs => pestañasBuscador[JuegoTipo.DLC].activa;
    private bool pestañaBandasSonoras => pestañasBuscador[JuegoTipo.Music].activa;
    private bool pestañaSoftware => pestañasBuscador[JuegoTipo.Software].activa;

    private string estiloJuegos => pestañasBuscador[JuegoTipo.Game].ObtenerEstilo();
    private string estiloDLCs => pestañasBuscador[JuegoTipo.DLC].ObtenerEstilo();
    private string estiloBandasSonoras => pestañasBuscador[JuegoTipo.Music].ObtenerEstilo();
    private string estiloSoftware => pestañasBuscador[JuegoTipo.Software].ObtenerEstilo();

    private void CambiarPestañas(MouseEventArgs e, int id)
    {
        var tipos = new[] { JuegoTipo.Game, JuegoTipo.DLC, JuegoTipo.Music, JuegoTipo.Software };

        foreach (var pestaña in pestañasBuscador.Values)
        {
            pestaña.activa = false;
        }

        if (id >= 0 && id < tipos.Length)
        {
            pestañasBuscador[tipos[id]].activa = true;
        }
    }

    private bool buscadorBuscando = false;
    private string _textoBuscador = string.Empty;
    private CancellationTokenSource _cts;
    private HashSet<int> idsPendientes = new(); 

    public string textoBuscador
    {
        get => _textoBuscador;
        set
        {
            _textoBuscador = value;
            _ = TextoCambiaBuscador();
        }
    }

    private async Task TextoCambiaBuscador()
    {
        buscadorBuscando = true;

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        try
        {
            if (_textoBuscador.Trim().Length <= 2)
            {
                LimpiarResultados();
                return;
            }

            await Task.Delay(100, token);

            var resultados = await BaseDatos.Juegos.Buscar.Nombre2(TiendaRegion.Europa, _textoBuscador, 250, true);

            if (token.IsCancellationRequested == true)
            {
                return;
            }

            ActualizarResultados(resultados);
            ActivarPrimeraPestañaDisponible();
        }
        catch (TaskCanceledException)
        {

        }
        finally
        {
            buscadorBuscando = false;
        }
    }

    private void ActualizarResultados(List<global::Juegos.Juego> resultados)
    {
        string nombreLimpio = Herramientas.Buscador.LimpiarNombre(_textoBuscador);

        foreach (PestañaBuscador pestaña in pestañasBuscador?.Values)
        {
            pestaña.resultados.RemoveAll(j => Herramientas.Buscador.LimpiarNombre(j.Nombre) != nombreLimpio);
        }

        var resultadosPorTipo = resultados.GroupBy(j => j.Tipo).ToDictionary(g => g.Key, g => g.ToList());

        foreach (var (tipo, pestaña) in pestañasBuscador)
        {
            if (resultadosPorTipo.TryGetValue(tipo, out var nuevosResultados))
            {
                var resultadosNuevos = nuevosResultados.Where(x => !pestaña.resultados.Any(y => y.Nombre == x.Nombre)).ToList();

                pestaña.resultados.AddRange(resultadosNuevos);
                pestaña.visible = pestaña.resultados.Count > 0;
            }
            else
            {
                pestaña.visible = pestaña.resultados.Count > 0;
            }
        }
    }

    private void ActivarPrimeraPestañaDisponible()
    {
        foreach (var pestaña in pestañasBuscador.Values)
        {
            pestaña.activa = false;
        }

        var orden = new[] { JuegoTipo.Game, JuegoTipo.DLC, JuegoTipo.Music, JuegoTipo.Software };

        foreach (var tipo in orden)
        {
            if (pestañasBuscador[tipo].visible)
            {
                pestañasBuscador[tipo].activa = true;
                break;
            }
        }
    }

    private void LimpiarResultados()
    {
        foreach (var pestaña in pestañasBuscador.Values)
        {
            pestaña.resultados.Clear();
            pestaña.visible = false;
            pestaña.activa = false;
        }

        pestañasBuscador[JuegoTipo.Game].activa = true; 
    }

    private void AgregarIdPendiente(global::Juegos.Juego juego)
    {
        idsPendientes.Add(juego.Id);

        idsPendiente = ObtenerIdsPendientesComoString();
        seleccionados.Add(juego);
    }

    private string ObtenerIdsPendientesComoString()
    {
        return idsPendientes.Count > 0 ? string.Join(",", idsPendientes) : "0";
    }

    private async Task ClickearIdPendientes(MouseEventArgs e, global::Juegos.Juego juego)
    {
        if (buscadorBuscando == true)
        {
            return;
        }

        buscadorBuscando = true;

        try
        {      
            AgregarIdPendiente(juego);
        }
        finally
        {
            buscadorBuscando = false;
        }
    }

    private async Task ClickearBorrarPendientes(MouseEventArgs e, string id)
    {
        if (buscadorBuscando == true)
        {
            return;
        }
    
        buscadorBuscando = true;

        try
        {
            await BaseDatos.Juegos.Borrar.Ejecutar(id);
        
            var resultados = await BaseDatos.Juegos.Buscar.Nombre2(TiendaRegion.Europa, _textoBuscador, 250, true);

            ActualizarResultados(resultados);
        }
        finally
        {
            buscadorBuscando = false;
        }
    }

    private IEnumerable<(JuegoTipo Tipo, (int Indice, string Titulo, int Ancho) Info)> ObtenerInfoPestañas()
    {
        return new[]
        {
            (JuegoTipo.Game, (0, "Juegos", 130)),
            (JuegoTipo.DLC, (1, "DLCs", 130)),
            (JuegoTipo.Music, (2, "Bandas Sonoras", 180)),
            (JuegoTipo.Software, (3, "Software", 130))
        };
    }

    #endregion

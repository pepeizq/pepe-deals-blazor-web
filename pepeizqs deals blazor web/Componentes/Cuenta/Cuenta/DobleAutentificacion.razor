@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Net.Codecrete.QrCodeGenerator
@using pepeizqs_deals_web.Data

@inject UserManager<Usuario> UserManager
@inject SignInManager<Usuario> SignInManager
@inject IHttpContextAccessor Contexto
@inject UrlEncoder UrlEncoder

@if (usuario?.TwoFactorEnabled == true)
{
    <div style="padding: 30px; display: flex; flex-direction: column; gap: 30px;">
        @if (recoveryCodes is not null)
        {
            if (recoveryCodes?.ToArray()?.Count() > 0)
            {
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <div>
                        @Herramientas.Idiomas.BuscarTexto(idioma, "String9", "AccountAuthenticator")
                    </div>
                    
                    @foreach (var recoveryCode in recoveryCodes.ToArray())
                    {
                        <div>
                            <code>@recoveryCode</code>
                        </div>
                    }
                </div>
            }
        }

        <div class="caja-cuenta-bloque">
            <form @formname="disable-2fa" @onsubmit="DesactivarDobleAutentificacion" method="post">
                <AntiforgeryToken />
                <button class="boton-pequeño" style="width: fit-content; padding: 10px 15px;" type="submit">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String8", "AccountAuthenticator")
                </button>

                <div style="margin-top: 20px; font-size: 14px;">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String12", "AccountAuthenticator")
                </div>
            </form>
        </div>

        <div class="caja-cuenta-bloque">
            <form @formname="reset-authenticator" @onsubmit="ResetearDobleAutentificacion" method="post">
                <AntiforgeryToken />
                <button class="boton-pequeño" style="width: fit-content; padding: 10px 15px;" type="submit">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String10", "AccountAuthenticator")
                </button>

                <div style="margin-top: 20px; font-size: 14px;">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String11", "AccountAuthenticator")
                </div>
            </form>
        </div>
    </div>
}

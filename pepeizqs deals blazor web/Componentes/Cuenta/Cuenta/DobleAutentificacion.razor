        <div>
            @Herramientas.Idiomas.BuscarTexto(idioma, "String1", "AccountAuthenticator")
        </div>

        <div class="caja-cuenta-bloque" style="display: flex; flex-direction: column; gap: 20px;">
            <div>
                @Herramientas.Idiomas.BuscarTexto(idioma, "String2", "AccountAuthenticator")

            </div>

            <div style="max-width: 300px;">
                @((MarkupString)qrSvg)
            </div>
        </div>

        <div class="caja-cuenta-bloque" style="display: flex; flex-direction: column; gap: 20px;">
            <div>
                @Herramientas.Idiomas.BuscarTexto(idioma, "String4", "AccountAuthenticator")
            </div>

            <EditForm Model="Input" FormName="send-code" OnValidSubmit="ActivarDobleAutentificacion" method="post">
                <DataAnnotationsValidator />
                <div>
                    <InputText @bind-Value="Input.Code" id="Input.Code" class="entrada-texto" autocomplete="off" placeholder="@Herramientas.Idiomas.BuscarTexto(idioma, "String6", "AccountAuthenticator")" />
                </div>

                <button type="submit" class="boton-pequeño" style="width: fit-content; margin-top: 15px; padding: 10px 15px;">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String7", "AccountAuthenticator")
                </button>
            </EditForm>

            @if (string.IsNullOrEmpty(mensajeError) == false)
            {
                <div style="background-color: var(--fondoPeligro); padding: 10px 15px; border-radius: 5px;">
                    @mensajeError
                </div>
            }
        </div>
    </div>
}

@code {

    #nullable disable

    [Parameter]
    public string idioma { get; set; }

    private const string AuthenticatorUriFormat = "otpauth://totp/{0}:{1}?secret={2}&issuer={0}&digits=6";

    private Usuario usuario = new Usuario();
    private string sharedKey;
    private string authenticatorUri;
    private IEnumerable<string> recoveryCodes;

    #pragma warning disable BL0008
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();
    #pragma warning restore BL0008

    private string qrSvg;
    private string mensajeError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        usuario = await UserManager.GetUserAsync(Contexto.HttpContext.User);

        await LoadSharedKeyAndQrCodeUriAsync(usuario);
    }

    private async Task ActivarDobleAutentificacion()
    {
        mensajeError = string.Empty;

        string codigoVerificacion = Input.Code.Replace(" ", string.Empty).Replace("-", string.Empty);

        bool tokenValido = await UserManager.VerifyTwoFactorTokenAsync(
            usuario, UserManager.Options.Tokens.AuthenticatorTokenProvider, codigoVerificacion);

        if (tokenValido == false)
        {
            mensajeError = Herramientas.Idiomas.BuscarTexto(idioma, "String5", "AccountAuthenticator");
            return;
        }

        await UserManager.SetTwoFactorEnabledAsync(usuario, true);

        if (await UserManager.CountRecoveryCodesAsync(usuario) == 0)
        {
            recoveryCodes = await UserManager.GenerateNewTwoFactorRecoveryCodesAsync(usuario, 10);
        }
    }

    private async ValueTask LoadSharedKeyAndQrCodeUriAsync(Usuario usuario)
    {
        var unformattedKey = await UserManager.GetAuthenticatorKeyAsync(usuario);

        if (string.IsNullOrEmpty(unformattedKey) == true)
        {
            await UserManager.ResetAuthenticatorKeyAsync(usuario);
            unformattedKey = await UserManager.GetAuthenticatorKeyAsync(usuario);
        }

        sharedKey = FormatKey(unformattedKey!);

        var email = await UserManager.GetEmailAsync(usuario);
        authenticatorUri = GenerateQrCodeUri(email!, unformattedKey!);

        var qr = QrCode.EncodeText(authenticatorUri!, QrCode.Ecc.Medium);
        qrSvg = qr.ToSvgString(4);
    }

    private string FormatKey(string unformattedKey)
    {
        var result = new StringBuilder();
        int currentPosition = 0;
        while (currentPosition + 4 < unformattedKey.Length)
        {
            result.Append(unformattedKey.AsSpan(currentPosition, 4)).Append(' ');
            currentPosition += 4;
        }
        if (currentPosition < unformattedKey.Length)
        {
            result.Append(unformattedKey.AsSpan(currentPosition));
        }

        return result.ToString().ToLowerInvariant();
    }

    private string GenerateQrCodeUri(string email, string unformattedKey)
    {
        return string.Format(
            CultureInfo.InvariantCulture,
            AuthenticatorUriFormat,
            UrlEncoder.Encode("pepe's deals"),
            UrlEncoder.Encode(email),
            unformattedKey);
    }

    private sealed class InputModel
    {
        [Required]
        [StringLength(7, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Text)]
        [Display(Name = "Verification Code")]
        public string Code { get; set; } = "";
    }

    private async Task DesactivarDobleAutentificacion()
    {
        await UserManager.SetTwoFactorEnabledAsync(usuario, false);
    }

    private async Task ResetearDobleAutentificacion()
    {
        await UserManager.SetTwoFactorEnabledAsync(usuario, false);
        await UserManager.ResetAuthenticatorKeyAsync(usuario);

        await SignInManager.RefreshSignInAsync(usuario);
    }
}

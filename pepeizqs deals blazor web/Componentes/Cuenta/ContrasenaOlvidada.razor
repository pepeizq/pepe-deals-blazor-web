@page "/account/forgot-password/"

@using Microsoft.AspNetCore.Components.Web;
@using Microsoft.AspNetCore.Identity;
@using Microsoft.AspNetCore.WebUtilities;
@using pepeizqs_deals_web.Data;
@using System.ComponentModel.DataAnnotations
@using System.Text;

@inject IHttpContextAccessor Contexto
@inject UserManager<Usuario> UserManager

<style>
    .caja-contraseña-contenido {
        background-color: var(--fondoSubsubcabecera);
        border: 2px solid var(--fondoSubcabecera);
        border-radius: 20px;
        box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.28),0px 0px 2px 0px rgba(0, 0, 0, 0.24);
        max-width: 600px;
    }

    .caja-contraseña-titulo {
        background: color-mix(in srgb, var(--fondoSubcabecera) 45%, var(--fondoBotonPequeño));
        padding: 20px 40px;
        border-top-left-radius: inherit;
        border-top-right-radius: inherit;
        font-size: 20px;
    }
</style>

@{
    string titulo = Herramientas.Idiomas.BuscarTexto(idioma, "String1", "ForgotPassword") + " • pepe's deals";
}

<HeadContent>
    <PageTitle>@titulo</PageTitle>
</HeadContent>

<div class="caja-contraseña-contenido" style="margin: 40px auto;">
    <div class="caja-contraseña-titulo">
        @Herramientas.Idiomas.BuscarTexto(idioma, "String1", "ForgotPassword")
    </div>

    <div style="display: flex; flex-direction: column; padding: 30px 40px 40px 40px;">
        <label class="texto-info-entrada">@Herramientas.Idiomas.BuscarTexto(idioma, "String2", "ForgotPassword")</label>
        <input @bind-value="correo" @bind-value:event="oninput" style="padding: 5px 10px; background-color: var(--fondoEntrada); border: 0px; color: var(--colorTexto); display: block;" />

        <div style="margin-top: 30px;">
            @if (enviando == false)
            {
                <button @onclick="EnviarCorreo" class="boton-pequeño" style="text-align: center; font-size: 20px; padding: 15px 20px;">
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String3", "ForgotPassword")
                </button>
            }
            else
            {
                <div>
                    @Herramientas.Idiomas.BuscarTexto(idioma, "String5", "ForgotPassword")
                </div>
            }
        </div>

        @if (string.IsNullOrEmpty(mensajeExito) == false)
        {
            <div class="alert alert-success alert-dismissible" style="margin-bottom: 0px; margin-top: 30px;" role="alert">
                @mensajeExito
            </div>
        }
    </div>
</div>

<Accesos idioma="@idioma" mostrarContraseñaOlvidada="false" />

@code {

    #nullable disable

    private string idioma = "en";
    private string dominio = null;

    private string correo = string.Empty;

    private string mensajeExito = string.Empty;

    protected override void OnInitialized()
    {
        Herramientas.ContextoUsuarioDatos datos = Herramientas.ContextoUsuario.Leer(Contexto);
        idioma = datos.Idioma;
        dominio = datos.Dominio;
    }

    private bool enviando = false;

    private async Task EnviarCorreo()
    {
        if (enviando == true)
        {
            return;
        }

        enviando = true;
        mensajeExito = null;

        try
        {
            EmailAddressAttribute comprobador = new EmailAddressAttribute();

            if (comprobador.IsValid(correo) == true)
            {
                Usuario usuario = await UserManager.FindByEmailAsync(correo);

                if (usuario?.EmailConfirmed == true)
                {
                    string codigo = await UserManager.GeneratePasswordResetTokenAsync(usuario);
                    codigo = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(codigo));

                    string enlaceFinal = "https://" + dominio + "/account/reset-password?code=" + codigo;

                    await Herramientas.Correos.Cuenta.ContraseñaOlvidada(idioma, enlaceFinal, correo);
                    mensajeExito = Herramientas.Idiomas.BuscarTexto(idioma, "String4", "ForgotPassword");
                    correo = string.Empty;
                }
            }
        }
        finally
        {
            enviando = false;
        }
    }
}

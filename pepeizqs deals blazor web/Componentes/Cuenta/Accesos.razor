@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Web

@inject NavigationManager NavManager

<div class="caja-accesos-contenido" style="margin: 40px auto;">
    <div style="display: flex; align-items: center;">

        @if (mostrarLogin == true)
        {
            <button @onclick="@(e => AbrirLogin(e))" class="boton-accesos">
                @Herramientas.Idiomas.BuscarTexto(idioma, "String3", "AccountLinks")
            </button>
        }

        @if (mostrarRegistro == true)
        {
            <button @onclick="@(e => AbrirRegistro(e))" class="boton-accesos">
                @Herramientas.Idiomas.BuscarTexto(idioma, "String2", "AccountLinks")
            </button>
        }

        @if (mostrarContraseñaOlvidada == true)
        {
            <button @onclick="@(e => AbrirContraseñaOlvidada(e))" class="boton-accesos">
                @Herramientas.Idiomas.BuscarTexto(idioma, "String1", "AccountLinks")
            </button>
        }
    </div>
</div>

@code {

    #nullable disable

    [Parameter]
    public string idioma { get; set; }

    [Parameter]
    public bool mostrarLogin { get; set; } = true;

    [Parameter]
    public bool mostrarRegistro { get; set; } = true;

    [Parameter]
    public bool mostrarContraseñaOlvidada { get; set; } = true;

    private void AbrirLogin(MouseEventArgs e)
    {
        NavManager.NavigateTo("/account/login/", true, false);
    }

    private void AbrirRegistro(MouseEventArgs e)
    {
        NavManager.NavigateTo("/account/register/", true, false);
    }

    private void AbrirContraseñaOlvidada(MouseEventArgs e)
    {
        NavManager.NavigateTo("/account/forgot-password/", true, false);
    }
}
